---
import Base from "../layouts/Base.astro";
---

<Base title="404 — FIREPRO Admin">
  <div class="min-h-screen bg-paper flex items-center justify-center px-4">
    <div class="text-center max-w-sm">
      <p class="font-display text-[8rem] text-ink leading-none opacity-10 select-none">404</p>
      <div class="-mt-8">
        <h1 class="font-display text-4xl text-ink mb-3">Halaman Tidak Ditemukan</h1>
        <p class="font-mono text-xs text-smoke uppercase tracking-wide mb-6">
          Halaman yang kamu cari tidak ada di dashboard ini.
        </p>
        <a href="/" class="btn-primary inline-flex">← Kembali ke Dashboard</a>
      </div>
    </div>
  </div>
</Base>