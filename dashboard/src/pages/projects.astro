---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<DashboardLayout title="Projects" activeNav="projects">
  <PageHeader heading="Projects" sub="Daftar proyek berjalan" crumbs={[{ label: "Operasional" }, { label: "Projects" }]}>
    <button id="btn-export-projects" type="button" class="btn-secondary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="1.75">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/>
        <line x1="9" y1="15" x2="15" y2="15"/>
      </svg>
      Export PDF
    </button>
  </PageHeader>

  <!-- Filter -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <input id="search-projects" type="search" placeholder="Cari ID proyek / nama klien…" class="field-input sm:max-w-xs" />
    <select id="filter-status" class="field-input sm:w-40">
      <option value="">Semua Status</option>
      <option value="planning">Perencanaan</option>
      <option value="in_progress">Berjalan</option>
      <option value="completed">Selesai</option>
      <option value="on_hold">Ditunda</option>
      <option value="cancelled">Dibatalkan</option>
    </select>
  </div>

  <!-- Table -->
  <div class="panel overflow-hidden">
    <div class="overflow-x-auto">
      <table id="projects-table" class="data-table">
        <thead>
          <tr>
            <th>Project ID</th>
            <th>Klien</th>
            <th class="hidden sm:table-cell">Mulai</th>
            <th>Nilai Kontrak</th>
            <th class="hidden md:table-cell">Lokasi</th>
            <th>Status</th>
            <th class="text-right">Aksi</th>
          </tr>
        </thead>
        <tbody id="projects-body"></tbody>
      </table>
    </div>
    <div id="projects-empty" class="empty-state min-h-56">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M5.5 8H18.5L19.5 21H4.5L5.5 8Z"/>
        <path d="M8.5 8V6C8.5 4.067 9.567 3 12 3C14.433 3 15.5 4.067 15.5 6V8"/>
      </svg>
      <p>Belum ada proyek berjalan</p>
    </div>
    <div class="flex items-center justify-between px-4 py-3 border-t border-hairline">
      <span data-projects-count class="font-mono text-[10px] text-smoke">0 proyek</span>
      <div class="flex items-center gap-1">
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>←</button>
        <span class="font-mono text-xs px-3 py-1.5 border border-hairline">1</span>
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>→</button>
      </div>
    </div>
  </div>

  <!-- Project Detail Drawer -->
  <div id="project-drawer" class="fixed inset-y-0 right-0 z-50 w-full sm:w-[420px] bg-paper border-l-2 border-ink translate-x-full transition-transform duration-300 ease-out flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink shrink-0">
      <h2 class="font-display text-xl text-ink">Detail Proyek</h2>
      <button id="drawer-close" type="button" class="text-smoke hover:text-ink p-1">
        <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="flex-1 overflow-y-auto p-5">
      <div id="drawer-content" class="empty-state min-h-40">
        <p>Pilih proyek untuk melihat detail</p>
      </div>
    </div>
  </div>
  <div id="drawer-overlay" class="fixed inset-0 bg-ink/40 z-40 hidden"></div>
</DashboardLayout>

<script>
  import { exportTableToPDF } from "../lib/export";
  import { adminApiFetch } from "../lib/auth";
  import { escapeHtml } from "../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface AdminProject {
    projectId: string;
    clientName: string;
    clientEmail: string;
    contractValue: number;
    status: string;
    startDate: string;
    projectName: string;
    projectCode: string;
    location: string;
    category: string | null;
    crewSize: number;
    additionalCost: number;
    baseCost: number;
    paymentRef: string | null;
  }

  let allProjects: AdminProject[] = [];

  const tbody = document.getElementById("projects-body") as HTMLTableSectionElement;
  const emptyState = document.getElementById("projects-empty") as HTMLDivElement;
  const countLabel = document.querySelector<HTMLSpanElement>("[data-projects-count]");
  const table = document.getElementById("projects-table") as HTMLTableElement;

  const STATUS_LABELS: Record<string, string> = {
    planning: "Perencanaan",
    in_progress: "Berjalan",
    completed: "Selesai",
    on_hold: "Ditunda",
    cancelled: "Dibatalkan",
  };
  const STATUS_CLASSES: Record<string, string> = {
    planning: "border-ink text-ink",
    in_progress: "border-ink bg-ink text-paper",
    completed: "border-armed text-armed",
    on_hold: "border-amber text-amber",
    cancelled: "border-smoke text-smoke",
  };

  function formatRupiah(value: number): string {
    return new Intl.NumberFormat("id-ID", {
      style: "currency", currency: "IDR", minimumFractionDigits: 0,
    }).format(value);
  }
  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString("id-ID", {
      day: "2-digit", month: "short", year: "numeric",
    });
  }

  function renderTable(projects: AdminProject[]): void {
    tbody.innerHTML = "";
    const isEmpty = projects.length === 0;
    table.classList.toggle("hidden", isEmpty);
    emptyState.classList.toggle("hidden", !isEmpty);
    if (countLabel) countLabel.textContent = `${projects.length} proyek`;

    projects.forEach((p) => {
      const statusLabel = STATUS_LABELS[p.status] ?? p.status;
      const statusClass = STATUS_CLASSES[p.status] ?? "border-smoke text-smoke";
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="font-mono text-xs">${escapeHtml(p.projectId)}</td>
        <td>
          <p class="font-semibold text-sm text-ink">${escapeHtml(p.clientName)}</p>
          <p class="font-mono text-[10px] text-smoke">${escapeHtml(p.clientEmail)}</p>
        </td>
        <td class="hidden sm:table-cell font-mono text-xs text-smoke">${formatDate(p.startDate)}</td>
        <td class="font-mono text-xs">${formatRupiah(p.contractValue)}</td>
        <td class="hidden md:table-cell font-mono text-xs text-smoke">${escapeHtml(p.location ?? "—")}</td>
        <td>
          <span class="font-mono text-[10px] uppercase tracking-wide px-2 py-0.5 border-2 ${statusClass}">
            ${statusLabel}
          </span>
        </td>
        <td class="text-right">
          <button type="button" class="btn-view-project text-xs px-2 py-1 hover:underline" data-project-id="${escapeHtml(p.projectId)}">
            Detail
          </button>
        </td>
      `;
      tbody.appendChild(tr);
    });

    tbody.querySelectorAll<HTMLButtonElement>(".btn-view-project").forEach((btn) => {
      btn.addEventListener("click", () => {
        const project = allProjects.find((p) => p.projectId === btn.dataset.projectId);
        if (project) openDrawer(project);
      });
    });
  }

  function applyFilters(): void {
    const keyword = (document.getElementById("search-projects") as HTMLInputElement)?.value
      .trim().toLowerCase() ?? "";
    const status = (document.getElementById("filter-status") as HTMLSelectElement)?.value ?? "";

    const filtered = allProjects.filter((p) => {
      if (keyword && !p.projectId.toLowerCase().includes(keyword) &&
          !p.clientName.toLowerCase().includes(keyword)) return false;
      if (status && p.status !== status) return false;
      return true;
    });
    renderTable(filtered);
  }

  async function loadProjects(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/projects/admin`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat proyek", "error");
        return;
      }
      allProjects = json.data ?? [];
      applyFilters();
    } catch {
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  document.getElementById("search-projects")?.addEventListener("input", applyFilters);
  document.getElementById("filter-status")?.addEventListener("change", applyFilters);

  // ─── Drawer detail proyek ────────────────────────────────────────
  const drawer = document.getElementById("project-drawer");
  const overlay = document.getElementById("drawer-overlay");
  const drawerContent = document.getElementById("drawer-content");

  function openDrawer(project: AdminProject): void {
    if (drawerContent) {
      drawerContent.innerHTML = `
        <div class="space-y-4">
          <div>
            <p class="font-mono text-[10px] text-smoke uppercase tracking-wide mb-1">Project ID</p>
            <p class="font-mono text-xs text-ink break-all">${escapeHtml(project.projectId)}</p>
          </div>
          <div>
            <p class="font-mono text-[10px] text-smoke uppercase tracking-wide mb-1">Nama Proyek</p>
            <p class="font-body text-sm text-ink font-semibold">${escapeHtml(project.projectName)}</p>
            <p class="font-mono text-xs text-smoke">Lokasi: ${escapeHtml(project.location)}${project.category ? ` / ${escapeHtml(project.category)}` : ""} × ${Number(project.crewSize)} tim</p>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <p class="font-mono text-[10px] text-smoke uppercase tracking-wide mb-1">Biaya Dasar</p>
              <p class="font-mono text-sm text-ink">${formatRupiah(project.baseCost)}</p>
            </div>
            <div>
              <p class="font-mono text-[10px] text-smoke uppercase tracking-wide mb-1">Biaya Tambahan</p>
              <p class="font-mono text-sm text-ink">${formatRupiah(project.additionalCost)}</p>
            </div>
          </div>
          <div>
            <p class="font-mono text-[10px] text-smoke uppercase tracking-wide mb-1">Nilai Kontrak</p>
            <p class="font-body text-xl text-ink font-bold">${formatRupiah(project.contractValue)}</p>
          </div>
          <hr class="border-hairline" />
          <div>
            <p class="font-mono text-[10px] text-smoke uppercase tracking-wide mb-1">Klien</p>
            <p class="font-body text-sm text-ink">${escapeHtml(project.clientName)}</p>
            <p class="font-mono text-xs text-smoke">${escapeHtml(project.clientEmail)}</p>
          </div>
          <div>
            <p class="font-mono text-[10px] text-smoke uppercase tracking-wide mb-1">Tanggal Mulai</p>
            <p class="font-mono text-xs text-ink">${formatDate(project.startDate)}</p>
          </div>
          ${project.paymentRef ? `
          <div>
            <p class="font-mono text-[10px] text-smoke uppercase tracking-wide mb-1">No. Referensi Pembayaran</p>
            <p class="font-mono text-xs text-ink break-all">${escapeHtml(project.paymentRef)}</p>
          </div>` : ""}
          <div>
            <p class="font-mono text-[10px] text-smoke uppercase tracking-wide mb-1">Status</p>
            <span class="font-mono text-[10px] uppercase tracking-wide px-2 py-0.5 border-2 ${STATUS_CLASSES[project.status] ?? "border-smoke text-smoke"}">
              ${STATUS_LABELS[project.status] ?? project.status}
            </span>
          </div>
        </div>
      `;
    }
    drawer?.classList.remove("translate-x-full");
    overlay?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeDrawer(): void {
    drawer?.classList.add("translate-x-full");
    overlay?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  document.getElementById("drawer-close")?.addEventListener("click", closeDrawer);
  overlay?.addEventListener("click", closeDrawer);

  document.getElementById("btn-export-projects")?.addEventListener("click", () => {
    exportTableToPDF("projects-table", { title: "Daftar Proyek", subtitle: "Laporan proyek FIREPRO" });
  });

  loadProjects();
</script>