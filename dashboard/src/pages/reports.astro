---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import StatCard from "../components/StatCard.astro";
---

<DashboardLayout title="Laporan" activeNav="reports">
  <PageHeader heading="Laporan" sub="Laporan ROI — monitoring performa bisnis" crumbs={[{ label: "Utama" }, { label: "Laporan" }]}>
    <button id="btn-export-report" type="button" class="btn-secondary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="1.75">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/>
        <line x1="9" y1="15" x2="15" y2="15"/>
      </svg>
      Export PDF
    </button>
    <!-- Input biaya iklan -->
    <button id="btn-input-cost" type="button" class="btn-primary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Input Biaya
    </button>
  </PageHeader>

  <!-- ROI Formula info -->
  <div class="mb-6 border-2 border-hairline bg-paper px-4 py-3 flex flex-col sm:flex-row sm:items-center gap-2">
    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 text-smoke shrink-0" stroke="currentColor" stroke-width="1.75">
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <p class="font-mono text-[10px] text-smoke uppercase tracking-wide">
      Formula: ROI = ((Revenue − Total Biaya) / Total Biaya) × 100%
    </p>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <StatCard id="stat-report-revenue" label="Total Revenue" accent />
    <StatCard id="stat-report-cost" label="Total Biaya" />
    <StatCard id="stat-report-profit" label="Gross Profit" />
    <StatCard id="stat-report-roi" label="ROI %" />
  </div>

  <!-- Input biaya section -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mb-6">

    <!-- Rincian Biaya -->
    <div class="panel">
      <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink">
        <div>
          <h3 class="font-display text-lg text-ink leading-none">Rincian Biaya</h3>
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Input manual per kategori</p>
        </div>
        <button id="btn-save-breakdown" type="button" class="btn-primary text-xs px-3 py-1.5">Simpan</button>
      </div>
      <div class="p-5 space-y-4">

        <div>
          <label class="field-label" for="cost-product">HPP / Harga Pokok Produk (Rp)</label>
          <input id="cost-product" type="number" placeholder="0" class="field-input" />
        </div>
        <div>
          <label class="field-label" for="cost-ads">Biaya Iklan (Rp)</label>
          <input id="cost-ads" type="number" placeholder="0" class="field-input" />
        </div>
        <div>
          <label class="field-label" for="cost-shipping">Biaya Pengiriman (Rp)</label>
          <input id="cost-shipping" type="number" placeholder="0" class="field-input" />
        </div>
        <div>
          <label class="field-label" for="cost-ops">Biaya Operasional (Rp)</label>
          <input id="cost-ops" type="number" placeholder="0" class="field-input" />
        </div>
        <div>
          <label class="field-label" for="cost-other">Lain-lain (Rp)</label>
          <input id="cost-other" type="number" placeholder="0" class="field-input" />
        </div>

        <div class="border-t-2 border-ink pt-4">
          <div class="flex justify-between items-center">
            <span class="font-mono text-xs text-smoke uppercase tracking-wide">Total Biaya</span>
            <span id="total-cost-display" class="font-display text-2xl text-ink">Rp 0</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ROI Hasil -->
    <div class="panel">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Kalkulasi ROI</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Data langsung dari invoice lunas &amp; biaya tercatat</p>
      </div>
      <div class="p-5 space-y-4">

        <div class="border-2 border-hairline p-4 space-y-3">
          <div class="flex justify-between items-center">
            <span class="font-mono text-[10px] text-smoke uppercase tracking-wide">Revenue</span>
            <span id="report-revenue" class="font-mono text-sm text-ink font-semibold">Rp 0</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="font-mono text-[10px] text-smoke uppercase tracking-wide">Total Biaya</span>
            <span id="report-cost" class="font-mono text-sm text-ink font-semibold">Rp 0</span>
          </div>
          <div class="border-t border-hairline pt-3 flex justify-between items-center">
            <span class="font-mono text-[10px] text-smoke uppercase tracking-wide">Gross Profit</span>
            <span id="report-profit" class="font-mono text-sm text-ink font-semibold">Rp 0</span>
          </div>
        </div>

        <!-- ROI display besar -->
        <div class="border-2 border-ink p-5 flex flex-col items-center justify-center gap-1 min-h-32">
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest">ROI</p>
          <p id="report-roi-value" class="font-display text-5xl text-ink leading-none">0%</p>
          <p class="font-mono text-[9px] text-smoke mt-1">Berdasarkan periode terpilih</p>
        </div>

        <!-- Period selector -->
        <div>
          <label class="field-label" for="report-period">Periode</label>
          <select id="report-period" class="field-input">
            <option value="this_month">Bulan Ini</option>
            <option value="last_month">Bulan Lalu</option>
            <option value="this_year">Tahun Ini</option>
            <option value="all_time">Semua Waktu</option>
            <option value="custom">Custom Range</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <!-- Biaya log table -->
  <div class="panel overflow-hidden">
    <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink">
      <div>
        <h3 class="font-display text-lg text-ink leading-none">Riwayat Input Biaya</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Log semua entri biaya</p>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table id="report-table" class="data-table">
        <thead>
          <tr>
            <th>Tanggal</th>
            <th>Kategori</th>
            <th>Keterangan</th>
            <th>Jumlah</th>
          </tr>
        </thead>
        <tbody id="report-body"></tbody>
      </table>
    </div>
    <div id="report-empty" class="empty-state min-h-44">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
      <p>Belum ada riwayat biaya — masukkan biaya pertama</p>
    </div>
  </div>

  <!-- Modal: Input Biaya Cepat -->
  <div id="cost-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-ink/50">
    <div class="bg-paper border-2 border-ink w-full max-w-sm brutal-shadow">
      <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink">
        <h2 class="font-display text-xl text-ink">Input Biaya</h2>
        <button id="cost-modal-close" type="button" class="text-smoke hover:text-ink p-1">
          <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="p-5 space-y-4">
        <div>
          <label class="field-label" for="cost-category">Kategori Biaya</label>
          <select id="cost-category" class="field-input">
            <option value="hpp">HPP / Harga Pokok</option>
            <option value="ads">Iklan</option>
            <option value="shipping">Pengiriman</option>
            <option value="ops">Operasional</option>
            <option value="other">Lain-lain</option>
          </select>
        </div>
        <div>
          <label class="field-label" for="cost-amount">Jumlah (Rp)</label>
          <input id="cost-amount" type="number" placeholder="0" class="field-input" />
        </div>
        <div>
          <label class="field-label" for="cost-note">Keterangan</label>
          <input id="cost-note" type="text" placeholder="Contoh: Meta Ads Mei 2026" class="field-input" />
        </div>
      </div>
      <div class="flex gap-3 px-5 py-4 border-t border-hairline">
        <button id="cost-modal-cancel" type="button" class="btn-secondary text-sm flex-1">Batal</button>
        <button id="cost-modal-save" type="button" class="btn-primary text-sm flex-1">Simpan</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { exportTableToPDF, formatIDR } from "../lib/export";
  import { adminApiFetch } from "../lib/auth";
  import { escapeHtml } from "../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface CostEntry {
    id: string;
    date: string;
    category: string;
    categoryLabel: string;
    amount: number;
    note: string;
  }

  interface ReportSummary {
    period: string;
    revenue: number;
    totalCost: number;
    grossProfit: number;
    roi: number;
  }

  function openModal(id: string) { document.getElementById(id)?.classList.replace("hidden", "flex"); }
  function closeModal(id: string) { document.getElementById(id)?.classList.replace("flex", "hidden"); }

  function currentPeriod(): string {
    return (document.getElementById("report-period") as HTMLSelectElement)?.value || "this_month";
  }

  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString("id-ID", { day: "2-digit", month: "short", year: "numeric" });
  }

  // ─── Riwayat biaya (tabel) ────────────────────────────────────────
  const reportBody = document.getElementById("report-body") as HTMLTableSectionElement;
  const reportEmpty = document.getElementById("report-empty") as HTMLDivElement;
  const reportTable = document.getElementById("report-table") as HTMLTableElement;

  function renderCostTable(entries: CostEntry[]): void {
    reportBody.innerHTML = "";
    const isEmpty = entries.length === 0;
    reportTable.classList.toggle("hidden", isEmpty);
    reportEmpty.classList.toggle("hidden", !isEmpty);

    entries.forEach((entry) => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="font-mono text-xs text-smoke">${formatDate(entry.date)}</td>
        <td class="text-xs">${escapeHtml(entry.categoryLabel)}</td>
        <td class="text-xs text-smoke">${escapeHtml(entry.note || "—")}</td>
        <td class="font-mono text-xs">${formatIDR(entry.amount)}</td>
      `;
      reportBody.appendChild(tr);
    });
  }

  async function loadCosts(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/reports/costs?period=${currentPeriod()}`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat riwayat biaya", "error");
        return;
      }
      renderCostTable(json.data ?? []);
    } catch (err) {
      console.error("[loadCosts] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  // ─── Ringkasan ROI (stat card + panel kalkulasi) ──────────────────
  function setStatValue(cardId: string, value: string): void {
    const card = document.getElementById(cardId);
    if (!card) return;
    let valueEl = card.querySelector<HTMLParagraphElement>(".stat-value");
    if (!valueEl) {
      const skeleton = card.querySelector(".animate-pulse")?.parentElement;
      valueEl = document.createElement("p");
      const isAccent = card.classList.contains("bg-ink");
      valueEl.className = `stat-value font-display text-3xl sm:text-4xl leading-none ${isAccent ? "text-paper" : "text-ink"}`;
      if (skeleton) {
        skeleton.replaceWith(valueEl);
      } else {
        card.appendChild(valueEl);
      }
    }
    valueEl.textContent = value;
  }

  async function loadSummary(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/reports/summary?period=${currentPeriod()}`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat ringkasan ROI", "error");
        return;
      }
      const summary: ReportSummary = json.data;

      setStatValue("stat-report-revenue", formatIDR(summary.revenue));
      setStatValue("stat-report-cost", formatIDR(summary.totalCost));
      setStatValue("stat-report-profit", formatIDR(summary.grossProfit));
      setStatValue("stat-report-roi", `${summary.roi}%`);

      const revenueEl = document.getElementById("report-revenue");
      const costEl = document.getElementById("report-cost");
      const profitEl = document.getElementById("report-profit");
      const roiEl = document.getElementById("report-roi-value");
      if (revenueEl) revenueEl.textContent = formatIDR(summary.revenue);
      if (costEl) costEl.textContent = formatIDR(summary.totalCost);
      if (profitEl) profitEl.textContent = formatIDR(summary.grossProfit);
      if (roiEl) roiEl.textContent = `${summary.roi}%`;
    } catch (err) {
      console.error("[loadSummary] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  function refreshAll(): void {
    loadCosts();
    loadSummary();
  }

  document.getElementById("report-period")?.addEventListener("change", refreshAll);

  // ─── Export ────────────────────────────────────────────────────
  document.getElementById("btn-export-report")?.addEventListener("click", () => {
    exportTableToPDF("report-table", { title: "Laporan ROI", subtitle: "Riwayat biaya dan kalkulasi ROI FIREPRO" });
  });

  // ─── Cost modal (input cepat 1 kategori) ──────────────────────────
  document.getElementById("btn-input-cost")?.addEventListener("click", () => openModal("cost-modal"));
  document.getElementById("cost-modal-close")?.addEventListener("click", () => closeModal("cost-modal"));
  document.getElementById("cost-modal-cancel")?.addEventListener("click", () => closeModal("cost-modal"));

  document.getElementById("cost-modal-save")?.addEventListener("click", async () => {
    const category = (document.getElementById("cost-category") as HTMLSelectElement).value;
    const amount = Number((document.getElementById("cost-amount") as HTMLInputElement).value);
    const note = (document.getElementById("cost-note") as HTMLInputElement).value.trim();

    if (!amount || amount <= 0) {
      window.showToast?.("Jumlah biaya wajib diisi dan lebih dari 0", "error");
      return;
    }

    const saveBtn = document.getElementById("cost-modal-save") as HTMLButtonElement;
    const originalLabel = saveBtn.textContent;
    saveBtn.disabled = true;
    saveBtn.textContent = "Menyimpan…";

    try {
      const res = await adminApiFetch(`${apiUrl}/api/reports/costs`, {
        method: "POST",
        body: JSON.stringify({ category, amount, note }),
      });
      const json = await res.json();

      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal menyimpan biaya", "error");
        return;
      }

      window.showToast?.(json.message ?? "Biaya berhasil disimpan");
      closeModal("cost-modal");
      (document.getElementById("cost-amount") as HTMLInputElement).value = "";
      (document.getElementById("cost-note") as HTMLInputElement).value = "";
      refreshAll();
    } catch (err) {
      console.error("[cost-modal-save] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = originalLabel;
    }
  });

  // ─── Live total cost calculator (panel "Rincian Biaya") ───────────
  const costFields = ["cost-product", "cost-ads", "cost-shipping", "cost-ops", "cost-other"];
  const totalDisplay = document.getElementById("total-cost-display");

  function recalcTotal() {
    let total = 0;
    costFields.forEach((id) => {
      const val = parseFloat((document.getElementById(id) as HTMLInputElement)?.value || "0");
      if (!isNaN(val)) total += val;
    });
    if (totalDisplay) totalDisplay.textContent = formatIDR(total);
  }

  costFields.forEach((id) => {
    document.getElementById(id)?.addEventListener("input", recalcTotal);
  });

  // Simpan semua kolom "Rincian Biaya" sekaligus — mapping id field ke
  // kategori backend (cost-product → hpp, dst).
  const FIELD_TO_CATEGORY: Record<string, string> = {
    "cost-product": "hpp",
    "cost-ads": "ads",
    "cost-shipping": "shipping",
    "cost-ops": "ops",
    "cost-other": "other",
  };

  document.getElementById("btn-save-breakdown")?.addEventListener("click", async () => {
    const payload: Record<string, number> = {};
    costFields.forEach((id) => {
      const category = FIELD_TO_CATEGORY[id];
      const val = parseFloat((document.getElementById(id) as HTMLInputElement)?.value || "0");
      payload[category] = isNaN(val) ? 0 : val;
    });

    if (Object.values(payload).every((v) => v <= 0)) {
      window.showToast?.("Isi minimal 1 kategori biaya", "error");
      return;
    }

    try {
      const res = await adminApiFetch(`${apiUrl}/api/reports/costs/breakdown`, {
        method: "POST",
        body: JSON.stringify(payload),
      });
      const json = await res.json();

      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal menyimpan rincian biaya", "error");
        return;
      }

      window.showToast?.(json.message ?? "Rincian biaya berhasil disimpan");
      costFields.forEach((id) => {
        (document.getElementById(id) as HTMLInputElement).value = "";
      });
      recalcTotal();
      refreshAll();
    } catch (err) {
      console.error("[btn-save-breakdown] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  });

  // ─── Init ──────────────────────────────────────────────────────
  refreshAll();
</script>