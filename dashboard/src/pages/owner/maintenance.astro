---
import OwnerLayout from "../../layouts/OwnerLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatCard from "../../components/StatCard.astro";
---

<OwnerLayout title="Maintenance" activeNav="maintenance">
  <PageHeader heading="Maintenance" sub="Jadwal perawatan sistem proteksi kebakaran" crumbs={[{ label: "Operasional" }, { label: "Maintenance" }]}>
    <button id="btn-add-maintenance" type="button" class="btn-primary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Jadwalkan
    </button>
  </PageHeader>

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <StatCard id="stat-maintenance-active" label="Jadwal Aktif" accent />
    <StatCard id="stat-maintenance-due-soon" label="Jatuh Tempo Minggu Ini" />
    <StatCard id="stat-maintenance-overdue" label="Terlambat" />
    <StatCard id="stat-maintenance-completed" label="Selesai Bulan Ini" />
  </div>

  <!-- Filter -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <input id="search-maintenance" type="search" placeholder="Cari klien / lokasi / peralatan…" class="field-input sm:max-w-xs" />
    <select id="filter-maintenance-status" class="field-input sm:w-44">
      <option value="">Semua Status</option>
      <option value="scheduled">Terjadwal</option>
      <option value="due_soon">Segera Jatuh Tempo</option>
      <option value="overdue">Terlambat</option>
      <option value="completed">Selesai</option>
    </select>
  </div>

  <!-- Table -->
  <div class="panel overflow-hidden">
    <div class="overflow-x-auto">
      <table id="maintenance-table" class="data-table">
        <thead>
          <tr>
            <th>Klien / Lokasi</th>
            <th class="hidden sm:table-cell">Peralatan</th>
            <th class="hidden md:table-cell">Jadwal Berikutnya</th>
            <th class="hidden md:table-cell">Teknisi</th>
            <th>Status</th>
            <th class="text-right">Aksi</th>
          </tr>
        </thead>
        <tbody id="maintenance-body"></tbody>
      </table>
    </div>
    <div id="maintenance-empty" class="empty-state min-h-56">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
      </svg>
      <p>Belum ada jadwal maintenance</p>
    </div>
    <div class="flex items-center justify-between px-4 py-3 border-t border-hairline">
      <span data-maintenance-count class="font-mono text-[10px] text-smoke">0 jadwal</span>
      <div class="flex items-center gap-1">
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>←</button>
        <span class="font-mono text-xs px-3 py-1.5 border border-hairline">1</span>
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>→</button>
      </div>
    </div>
  </div>
</OwnerLayout>

<script>
  // Prototype UI only — belum terhubung ke endpoint maintenance.
  document.getElementById("btn-add-maintenance")?.addEventListener("click", () => {
    window.showToast?.("Form jadwalkan maintenance (prototype)", "info");
  });
</script>
