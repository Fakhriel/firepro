---
import OwnerLayout from "../../layouts/OwnerLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatCard from "../../components/StatCard.astro";
---

<OwnerLayout title="Attendance" activeNav="attendance">
  <PageHeader heading="Attendance" sub="Pantau kehadiran seluruh tim lapangan" crumbs={[{ label: "Gudang & Analitik" }, { label: "Attendance" }]}>
    <button id="btn-export-attendance" type="button" class="btn-secondary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="1.75">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/>
        <line x1="9" y1="15" x2="15" y2="15"/>
      </svg>
      Export Rekap
    </button>
  </PageHeader>

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <StatCard id="stat-attendance-checked-in" label="Sudah Check In" accent />
    <StatCard id="stat-attendance-not-in" label="Belum Check In" />
    <StatCard id="stat-attendance-late" label="Terlambat" />
    <StatCard id="stat-attendance-absent" label="Tidak Hadir" />
  </div>

  <!-- Filter -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <input id="search-attendance" type="search" placeholder="Cari nama karyawan…" class="field-input sm:max-w-xs" />
    <select id="filter-attendance-role" class="field-input sm:w-44">
      <option value="">Semua Role</option>
      <option value="supervisor">Supervisor</option>
      <option value="karyawan">Teknisi Lapangan</option>
    </select>
    <select id="filter-attendance-status" class="field-input sm:w-44">
      <option value="">Semua Status</option>
      <option value="checked_in">Sedang Bekerja</option>
      <option value="checked_out">Sudah Pulang</option>
      <option value="not_in">Belum Check In</option>
      <option value="absent">Tidak Hadir</option>
    </select>
    <input id="filter-attendance-date" type="date" class="field-input sm:w-44" />
  </div>

  <!-- Table -->
  <div class="panel overflow-hidden">
    <div class="overflow-x-auto">
      <table id="attendance-table" class="data-table">
        <thead>
          <tr>
            <th>Nama</th>
            <th class="hidden sm:table-cell">Role</th>
            <th class="hidden sm:table-cell">Proyek</th>
            <th>Jam Masuk</th>
            <th>Jam Keluar</th>
            <th class="hidden md:table-cell">Durasi</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="attendance-body"></tbody>
      </table>
    </div>
    <div id="attendance-empty" class="empty-state min-h-56">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 16 14"/>
      </svg>
      <p>Belum ada data kehadiran untuk tanggal ini</p>
    </div>
    <div class="flex items-center justify-between px-4 py-3 border-t border-hairline">
      <span data-attendance-count class="font-mono text-[10px] text-smoke">0 karyawan</span>
      <div class="flex items-center gap-1">
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>←</button>
        <span class="font-mono text-xs px-3 py-1.5 border border-hairline">1</span>
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>→</button>
      </div>
    </div>
  </div>
</OwnerLayout>

<script>
  import { adminApiFetch } from "../../lib/auth";
  import { escapeHtml } from "../../lib/escapeHtml";
  import { exportTableToPDF } from "../../lib/export";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface AttendanceRecord {
    id: string;
    adminId: number;
    workDate: string;
    checkInAt: string | null;
    checkOutAt: string | null;
    status: string;
    admin?: { id: number; name: string; username: string; role?: string };
  }

  interface TeamUser {
    id: number;
    name: string;
    role: "supervisor" | "karyawan";
  }

  interface RowData {
    userId: number;
    name: string;
    role: string;
    checkInAt: string | null;
    checkOutAt: string | null;
    status: "checked_in" | "checked_out" | "not_in";
  }

  const dateInput = document.getElementById("filter-attendance-date") as HTMLInputElement | null;
  const searchInput = document.getElementById("search-attendance") as HTMLInputElement | null;
  const roleFilter = document.getElementById("filter-attendance-role") as HTMLSelectElement | null;
  const statusFilter = document.getElementById("filter-attendance-status") as HTMLSelectElement | null;
  const tableBody = document.getElementById("attendance-body") as HTMLTableSectionElement;
  const emptyState = document.getElementById("attendance-empty") as HTMLDivElement;
  const table = document.getElementById("attendance-table") as HTMLTableElement;
  const countLabel = document.querySelector("[data-attendance-count]") as HTMLElement | null;

  if (dateInput) {
    dateInput.value = new Date().toISOString().split("T")[0];
  }

  let allRows: RowData[] = [];

  function setStatValue(cardId: string, value: string): void {
    const card = document.getElementById(cardId);
    if (!card) return;
    let valueEl = card.querySelector<HTMLParagraphElement>(".stat-value");
    if (!valueEl) {
      const skeleton = card.querySelector(".animate-pulse")?.parentElement;
      valueEl = document.createElement("p");
      const isAccent = card.classList.contains("bg-ink");
      valueEl.className = `stat-value font-display text-3xl sm:text-4xl leading-none ${isAccent ? "text-paper" : "text-ink"}`;
      if (skeleton) {
        skeleton.replaceWith(valueEl);
      } else {
        card.appendChild(valueEl);
      }
    }
    valueEl.textContent = value;
  }

  function formatTime(iso: string | null): string {
    if (!iso) return "-";
    try {
      return new Date(iso).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
    } catch {
      return "-";
    }
  }

  function formatDuration(checkIn: string | null, checkOut: string | null): string {
    if (!checkIn || !checkOut) return "-";
    const ms = new Date(checkOut).getTime() - new Date(checkIn).getTime();
    if (ms <= 0) return "-";
    const hours = Math.floor(ms / 3600000);
    const minutes = Math.floor((ms % 3600000) / 60000);
    return `${hours}j ${minutes}m`;
  }

  const STATUS_LABEL: Record<string, string> = {
    checked_in: "Sedang Bekerja",
    checked_out: "Sudah Pulang",
    not_in: "Belum Check In",
  };
  const STATUS_BADGE: Record<string, string> = {
    checked_in: "bg-ink/5 text-ink border-ink",
    checked_out: "bg-hairline/20 text-smoke border-hairline",
    not_in: "bg-signal/10 text-signal border-signal",
  };
  const ROLE_LABEL: Record<string, string> = {
    supervisor: "Supervisor",
    karyawan: "Teknisi Lapangan",
  };

  function applyFiltersAndRender(): void {
    const keyword = (searchInput?.value ?? "").trim().toLowerCase();
    const role = roleFilter?.value ?? "";
    const status = statusFilter?.value ?? "";

    const filtered = allRows.filter((r) => {
      if (keyword && !r.name.toLowerCase().includes(keyword)) return false;
      if (role && r.role !== role) return false;
      if (status && status !== "absent" && r.status !== status) return false;
      if (status === "absent") return false; // backend belum punya konsep "tidak hadir" eksplisit
      return true;
    });

    tableBody.innerHTML = "";
    const isEmpty = filtered.length === 0;
    table.classList.toggle("hidden", isEmpty);
    emptyState.classList.toggle("hidden", !isEmpty);
    if (countLabel) countLabel.textContent = `${filtered.length} karyawan`;

    filtered.forEach((r) => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="font-semibold text-ink">${escapeHtml(r.name)}</td>
        <td class="hidden sm:table-cell font-mono text-xs text-charcoal">${escapeHtml(ROLE_LABEL[r.role] ?? r.role)}</td>
        <td class="hidden sm:table-cell font-mono text-xs text-charcoal">-</td>
        <td class="font-mono text-xs text-charcoal">${formatTime(r.checkInAt)}</td>
        <td class="font-mono text-xs text-charcoal">${formatTime(r.checkOutAt)}</td>
        <td class="hidden md:table-cell font-mono text-xs text-charcoal">${formatDuration(r.checkInAt, r.checkOutAt)}</td>
        <td><span class="font-mono text-[9px] uppercase tracking-widest border px-2 py-1 ${STATUS_BADGE[r.status]}">${STATUS_LABEL[r.status]}</span></td>
      `;
      tableBody.appendChild(tr);
    });
  }

  function updateStats(rows: RowData[]): void {
    setStatValue("stat-attendance-checked-in", String(rows.filter((r) => r.status === "checked_in" || r.status === "checked_out").length));
    setStatValue("stat-attendance-not-in", String(rows.filter((r) => r.status === "not_in").length));
    // Backend belum menandai keterlambatan/ketidakhadiran eksplisit — 0 sampai ada endpoint-nya.
    setStatValue("stat-attendance-late", "0");
    setStatValue("stat-attendance-absent", "0");
  }

  async function loadAttendance(): Promise<void> {
    const date = dateInput?.value || new Date().toISOString().split("T")[0];
    try {
      const [teamRes, attRes] = await Promise.all([
        adminApiFetch(`${apiUrl}/api/owner/users`),
        adminApiFetch(`${apiUrl}/api/owner/attendance/team?date=${date}`),
      ]);
      const teamJson = await teamRes.json();
      const attJson = await attRes.json();
      if (!teamRes.ok || !attRes.ok) {
        window.showToast?.(teamJson.error ?? attJson.error ?? "Gagal memuat data kehadiran", "error");
        return;
      }

      const teamUsers: TeamUser[] = (teamJson.data ?? []).filter(
        (u: { role: string }) => u.role === "supervisor" || u.role === "karyawan"
      );
      const records: AttendanceRecord[] = attJson.data ?? [];
      const recordByAdminId = new Map(records.map((r) => [r.adminId, r]));

      allRows = teamUsers.map((u) => {
        const rec = recordByAdminId.get(u.id);
        let status: RowData["status"] = "not_in";
        if (rec?.checkOutAt) status = "checked_out";
        else if (rec?.checkInAt) status = "checked_in";
        return {
          userId: u.id,
          name: u.name,
          role: u.role,
          checkInAt: rec?.checkInAt ?? null,
          checkOutAt: rec?.checkOutAt ?? null,
          status,
        };
      });

      applyFiltersAndRender();
      updateStats(allRows);
    } catch (err) {
      console.error("[loadAttendance] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  dateInput?.addEventListener("change", loadAttendance);
  searchInput?.addEventListener("input", applyFiltersAndRender);
  roleFilter?.addEventListener("change", applyFiltersAndRender);
  statusFilter?.addEventListener("change", applyFiltersAndRender);

  document.getElementById("btn-export-attendance")?.addEventListener("click", () => {
    exportTableToPDF("attendance-table", { title: "Rekap Kehadiran", subtitle: `Tanggal ${dateInput?.value ?? "-"} — FIREPRO` });
  });

  loadAttendance();
</script>
