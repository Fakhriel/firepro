---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<DashboardLayout title="Inventory" activeNav="inventory">
  <PageHeader heading="Inventory" sub="Kelola material &amp; peralatan FIREPRO" crumbs={[{ label: "Gudang" }, { label: "Inventory" }]}>
    <button id="btn-export-pdf" type="button" class="btn-secondary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="1.75">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/>
        <line x1="9" y1="15" x2="15" y2="15"/>
      </svg>
      Export PDF
    </button>
    <button id="btn-add-item" type="button" class="btn-primary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Tambah Barang
    </button>
  </PageHeader>

  <!-- Filter bar -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <input
      id="search-item"
      type="search"
      placeholder="Cari nama barang…"
      class="field-input sm:max-w-xs"
    />
    <select id="filter-type" class="field-input sm:w-36">
      <option value="">Semua Tipe</option>
      <option value="material">Material</option>
      <option value="peralatan">Peralatan</option>
    </select>
    <select id="filter-status" class="field-input sm:w-36">
      <option value="">Semua Status</option>
      <option value="active">Aktif</option>
      <option value="inactive">Nonaktif</option>
    </select>
  </div>

  <!-- Table -->
  <div class="panel overflow-hidden">
    <div class="overflow-x-auto">
      <table id="inventory-table" class="data-table">
        <thead>
          <tr>
            <th class="w-10">#</th>
            <th>Barang</th>
            <th class="hidden sm:table-cell">Kode</th>
            <th>Harga Satuan</th>
            <th class="hidden md:table-cell">Tipe</th>
            <th class="hidden md:table-cell">Stok</th>
            <th>Status</th>
            <th class="text-right">Aksi</th>
          </tr>
        </thead>
        <tbody id="inventory-body">
          <!-- Diisi via JS setelah konek backend -->
        </tbody>
      </table>
    </div>

    <!-- Empty state -->
    <div id="inventory-empty" class="empty-state min-h-56">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
      </svg>
      <p>Belum ada barang — tambahkan barang pertama</p>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-4 py-3 border-t border-hairline">
      <span id="inventory-count" class="font-mono text-[10px] text-smoke">0 barang</span>
      <div class="flex items-center gap-1">
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>←</button>
        <span class="font-mono text-xs px-3 py-1.5 border border-hairline">1</span>
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>→</button>
      </div>
    </div>
  </div>

  <!-- Modal: Tambah / Edit Barang -->
  <div id="item-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-ink/50">
    <div class="bg-paper border-2 border-ink w-full max-w-lg max-h-[90vh] overflow-y-auto brutal-shadow">
      <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink sticky top-0 bg-paper">
        <h2 id="modal-title" class="font-display text-xl text-ink">Tambah Barang</h2>
        <button id="modal-close" type="button" class="text-smoke hover:text-ink transition-colors p-1">
          <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <div class="p-5 space-y-4">
        <input type="hidden" id="item-id" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <label class="field-label" for="item-name">Nama Barang</label>
            <input id="item-name" type="text" placeholder="Semen Portland 50kg" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="item-category">Kategori</label>
            <input id="item-category" type="text" placeholder="Material, Alat Berat, dst" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="item-type">Tipe</label>
            <select id="item-type" class="field-input">
              <option value="material">Material</option>
              <option value="peralatan">Peralatan</option>
            </select>
          </div>
          <div>
            <label class="field-label" for="item-price">Harga Satuan (Rp)</label>
            <input id="item-price" type="number" placeholder="85000" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="item-old-price">Harga Lama (Rp) <span class="text-smoke normal-case">— opsional</span></label>
            <input id="item-old-price" type="number" placeholder="95000" class="field-input" />
          </div>
          <div class="sm:col-span-2">
            <label class="field-label" for="item-badge">Badge <span class="text-smoke normal-case">— opsional</span></label>
            <select id="item-badge" class="field-input">
              <option value="">Tidak ada</option>
              <option value="Baru">Baru</option>
              <option value="Stok Menipis">Stok Menipis</option>
              <option value="Sering Dipakai">Sering Dipakai</option>
            </select>
          </div>
          <div class="sm:col-span-2">
            <label class="field-label" for="item-desc">Deskripsi</label>
            <textarea id="item-desc" rows="3" placeholder="Deskripsi singkat barang…" class="field-input resize-none"></textarea>
          </div>

          <!-- Foto barang: multi-URL, foto pertama jadi cover -->
          <div class="sm:col-span-2">
            <div class="flex items-center justify-between mb-1.5">
              <label class="field-label" style="margin-bottom: 0;">Foto Barang (URL)</label>
              <button id="btn-add-image" type="button" class="text-[10px] font-mono uppercase tracking-wide text-signal hover:underline">
                + Tambah Foto
              </button>
            </div>
            <div id="image-rows" class="space-y-2"></div>
            <p class="font-mono text-[9px] text-smoke mt-1.5">Foto pertama jadi foto sampul (cover) barang.</p>
          </div>

          <!-- Varian & stok: dinamis, minimal 1 baris -->
          <div class="sm:col-span-2">
            <div class="flex items-center justify-between mb-1.5">
              <label class="field-label" style="margin-bottom: 0;">Varian &amp; Stok</label>
              <button id="btn-add-variant" type="button" class="text-[10px] font-mono uppercase tracking-wide text-signal hover:underline">
                + Tambah Varian
              </button>
            </div>
            <div id="variant-rows" class="space-y-2"></div>
          </div>

          <div class="sm:col-span-2">
            <label class="field-label" for="item-status">Status</label>
            <select id="item-status" class="field-input">
              <option value="active">Aktif</option>
              <option value="inactive">Nonaktif</option>
            </select>
          </div>
        </div>

        <!-- Error inline form -->
        <div id="item-form-error" class="hidden border-2 border-signal bg-signal/5 px-3 py-2.5">
          <p class="font-mono text-xs text-signal" id="item-form-error-msg"></p>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 px-5 py-4 border-t border-hairline">
        <button id="modal-cancel" type="button" class="btn-secondary text-sm">Batal</button>
        <button id="modal-save" type="button" class="btn-primary text-sm">Simpan</button>
      </div>
    </div>
  </div>

  <!-- Modal: Konfirmasi Hapus -->
  <div id="delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-ink/50">
    <div class="bg-paper border-2 border-ink w-full max-w-sm brutal-shadow">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h2 class="font-display text-xl text-ink">Hapus Barang?</h2>
      </div>
      <div class="px-5 py-4">
        <p class="font-body text-sm text-charcoal">Barang <strong id="delete-item-name" class="text-ink"></strong> akan dihapus permanen. Tindakan ini tidak bisa dibatalkan.</p>
      </div>
      <div class="flex gap-3 px-5 py-4 border-t border-hairline">
        <button id="delete-cancel" type="button" class="btn-secondary text-sm flex-1">Batal</button>
        <button id="delete-confirm" type="button" class="btn-danger text-sm flex-1">Hapus</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { exportTableToPDF } from "../lib/export";
  import { adminApiFetch } from "../lib/auth";
  import { escapeHtml } from "../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface AdminInventoryItem {
    id: string;
    code: string;
    name: string;
    category: string;
    type: "material" | "peralatan";
    price: number;
    oldPrice: number | null;
    badge: "Baru" | "Stok Menipis" | "Sering Dipakai" | null;
    isActive: number | boolean;
    image: string | null;
    totalStock: number;
  }

  interface InventoryItemDetail extends AdminInventoryItem {
    description: string;
    images: string[];
    variants: { variant: string; stock: number }[];
  }

  let allItems: AdminInventoryItem[] = [];
  let itemBeingDeleted: { id: string; name: string } | null = null;

  const tableBody = document.getElementById("inventory-body") as HTMLTableSectionElement;
  const emptyState = document.getElementById("inventory-empty") as HTMLDivElement;
  const countLabel = document.getElementById("inventory-count") as HTMLSpanElement;
  const table = document.getElementById("inventory-table") as HTMLTableElement;

  function formatRupiah(value: number): string {
    return new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", minimumFractionDigits: 0 }).format(value);
  }

  // ─── Render tabel ───────────────────────────────────────────────
  function renderTable(items: AdminInventoryItem[]): void {
    tableBody.innerHTML = "";

    const isEmpty = items.length === 0;
    table.classList.toggle("hidden", isEmpty);
    emptyState.classList.toggle("hidden", !isEmpty);
    countLabel.textContent = `${items.length} barang`;

    items.forEach((it, index) => {
      const isActive = Boolean(it.isActive);
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="font-mono text-xs text-smoke">${index + 1}</td>
        <td>
          <div class="flex items-center gap-2.5">
            <img src="${escapeHtml(it.image ?? "/favicon.svg")}" alt="${escapeHtml(it.name)}" class="w-9 h-9 object-cover border border-hairline shrink-0" />
            <div class="min-w-0">
              <p class="font-semibold text-ink truncate">${escapeHtml(it.name)}</p>
              <p class="font-mono text-[10px] text-smoke truncate">${escapeHtml(it.category)}</p>
            </div>
          </div>
        </td>
        <td class="hidden sm:table-cell font-mono text-xs text-smoke">${escapeHtml(it.code)}</td>
        <td class="font-mono text-xs">${formatRupiah(it.price)}</td>
        <td class="hidden md:table-cell capitalize text-xs">${escapeHtml(it.type)}</td>
        <td class="hidden md:table-cell font-mono text-xs">${Number(it.totalStock)}</td>
        <td>
          <span class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wide border ${isActive ? "border-ink text-ink" : "border-smoke text-smoke"}">
            ${isActive ? "Aktif" : "Nonaktif"}
          </span>
        </td>
        <td class="text-right whitespace-nowrap">
          <button type="button" class="btn-edit-item text-xs px-2 py-1 hover:underline" data-id="${it.id}">Edit</button>
          <button type="button" class="btn-delete-item text-xs px-2 py-1 text-signal hover:underline" data-id="${it.id}" data-name="${escapeHtml(it.name)}">Hapus</button>
        </td>
      `;
      tableBody.appendChild(tr);
    });

    table.querySelectorAll<HTMLButtonElement>(".btn-edit-item").forEach((btn) => {
      btn.addEventListener("click", () => openEditModal(btn.dataset.id!));
    });
    table.querySelectorAll<HTMLButtonElement>(".btn-delete-item").forEach((btn) => {
      btn.addEventListener("click", () => {
        itemBeingDeleted = { id: btn.dataset.id!, name: btn.dataset.name! };
        (document.getElementById("delete-item-name") as HTMLElement).textContent = itemBeingDeleted.name;
        openModal("delete-modal");
      });
    });
  }

  function applyFilters(): void {
    const keyword = (document.getElementById("search-item") as HTMLInputElement).value.trim().toLowerCase();
    const type = (document.getElementById("filter-type") as HTMLSelectElement).value;
    const status = (document.getElementById("filter-status") as HTMLSelectElement).value;

    const filtered = allItems.filter((it) => {
      if (keyword && !it.name.toLowerCase().includes(keyword)) return false;
      if (type && it.type !== type) return false;
      if (status === "active" && !it.isActive) return false;
      if (status === "inactive" && it.isActive) return false;
      return true;
    });

    renderTable(filtered);
  }

  async function loadInventory(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/inventory/admin`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat inventory", "error");
        return;
      }
      allItems = json.data ?? [];
      applyFilters();
    } catch (err) {
      console.error("[loadInventory] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  document.getElementById("search-item")?.addEventListener("input", applyFilters);
  document.getElementById("filter-type")?.addEventListener("change", applyFilters);
  document.getElementById("filter-status")?.addEventListener("change", applyFilters);

  // ─── Modal helpers ────────────────────────────────────────────────
  function openModal(id: string): void {
    const el = document.getElementById(id);
    el?.classList.remove("hidden");
    el?.classList.add("flex");
  }
  function closeModal(id: string): void {
    const el = document.getElementById(id);
    el?.classList.add("hidden");
    el?.classList.remove("flex");
  }

  // ─── Baris dinamis: Varian & Stok ──────────────────────────────────
  const variantRowsContainer = document.getElementById("variant-rows") as HTMLDivElement;

  function addVariantRow(variant = "", stock = ""): void {
    const row = document.createElement("div");
    row.className = "flex gap-2 variant-row";
    row.innerHTML = `
      <input type="text" placeholder="Varian (mis. 50kg)" class="field-input variant-input flex-1" value="${escapeHtml(variant)}" />
      <input type="number" placeholder="Stok" min="0" class="field-input stock-input w-24" value="${escapeHtml(stock)}" />
      <button type="button" class="btn-remove-row btn-secondary px-2.5" aria-label="Hapus varian">×</button>
    `;
    row.querySelector(".btn-remove-row")?.addEventListener("click", () => {
      // Selalu sisakan minimal 1 baris supaya form tidak pernah
      // ke-submit tanpa varian sama sekali.
      if (variantRowsContainer.children.length > 1) row.remove();
    });
    variantRowsContainer.appendChild(row);
  }

  document.getElementById("btn-add-variant")?.addEventListener("click", () => addVariantRow());

  function getVariantsFromForm(): { variant: string; stock: number }[] {
    return Array.from(variantRowsContainer.querySelectorAll(".variant-row"))
      .map((row) => {
        const variant = (row.querySelector(".variant-input") as HTMLInputElement).value.trim();
        const stock = Number((row.querySelector(".stock-input") as HTMLInputElement).value) || 0;
        return { variant, stock };
      })
      .filter((v) => v.variant);
  }

  // ─── Baris dinamis: Foto (URL) ───────────────────────────────────
  const imageRowsContainer = document.getElementById("image-rows") as HTMLDivElement;

  function addImageRow(url = ""): void {
    const row = document.createElement("div");
    row.className = "flex gap-2 image-row";
    row.innerHTML = `
      <input type="text" placeholder="https://...jpg" class="field-input image-input flex-1" value="${escapeHtml(url)}" />
      <button type="button" class="btn-remove-row btn-secondary px-2.5" aria-label="Hapus foto">×</button>
    `;
    row.querySelector(".btn-remove-row")?.addEventListener("click", () => {
      if (imageRowsContainer.children.length > 1) row.remove();
    });
    imageRowsContainer.appendChild(row);
  }

  document.getElementById("btn-add-image")?.addEventListener("click", () => addImageRow());

  function getImagesFromForm(): string[] {
    return Array.from(imageRowsContainer.querySelectorAll(".image-input"))
      .map((input) => (input as HTMLInputElement).value.trim())
      .filter(Boolean);
  }

  // ─── Form error helper ──────────────────────────────────────────
  function showFormError(msg: string): void {
    const box = document.getElementById("item-form-error");
    const msgEl = document.getElementById("item-form-error-msg");
    if (msgEl) msgEl.textContent = msg;
    box?.classList.remove("hidden");
  }
  function hideFormError(): void {
    document.getElementById("item-form-error")?.classList.add("hidden");
  }

  function resetForm(): void {
    (document.getElementById("item-id") as HTMLInputElement).value = "";
    (document.getElementById("item-name") as HTMLInputElement).value = "";
    (document.getElementById("item-category") as HTMLInputElement).value = "";
    (document.getElementById("item-type") as HTMLSelectElement).value = "material";
    (document.getElementById("item-price") as HTMLInputElement).value = "";
    (document.getElementById("item-old-price") as HTMLInputElement).value = "";
    (document.getElementById("item-badge") as HTMLSelectElement).value = "";
    (document.getElementById("item-desc") as HTMLTextAreaElement).value = "";
    (document.getElementById("item-status") as HTMLSelectElement).value = "active";
    variantRowsContainer.innerHTML = "";
    imageRowsContainer.innerHTML = "";
    addVariantRow();
    addImageRow();
    hideFormError();
  }

  // ─── Tambah barang ──────────────────────────────────────────────
  document.getElementById("btn-add-item")?.addEventListener("click", () => {
    resetForm();
    (document.getElementById("modal-title") as HTMLElement).textContent = "Tambah Barang";
    (document.getElementById("modal-save") as HTMLButtonElement).textContent = "Simpan";
    openModal("item-modal");
  });

  // ─── Edit barang: ambil detail lengkap dari backend ───────────────
  async function openEditModal(id: string): Promise<void> {
    resetForm();
    try {
      const res = await adminApiFetch(`${apiUrl}/api/inventory/${id}`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat detail barang", "error");
        return;
      }
      const item: InventoryItemDetail = json.data;

      (document.getElementById("item-id") as HTMLInputElement).value = item.id;
      (document.getElementById("item-name") as HTMLInputElement).value = item.name;
      (document.getElementById("item-category") as HTMLInputElement).value = item.category;
      (document.getElementById("item-type") as HTMLSelectElement).value = item.type;
      (document.getElementById("item-price") as HTMLInputElement).value = String(item.price);
      (document.getElementById("item-old-price") as HTMLInputElement).value =
        item.oldPrice != null ? String(item.oldPrice) : "";
      (document.getElementById("item-badge") as HTMLSelectElement).value = item.badge ?? "";
      (document.getElementById("item-desc") as HTMLTextAreaElement).value = item.description;
      (document.getElementById("item-status") as HTMLSelectElement).value = item.isActive ? "active" : "inactive";

      imageRowsContainer.innerHTML = "";
      (item.images.length ? item.images : [""]).forEach((url) => addImageRow(url));

      variantRowsContainer.innerHTML = "";
      (item.variants.length ? item.variants : [{ variant: "", stock: 0 }]).forEach((v) =>
        addVariantRow(v.variant, String(v.stock))
      );

      (document.getElementById("modal-title") as HTMLElement).textContent = "Edit Barang";
      (document.getElementById("modal-save") as HTMLButtonElement).textContent = "Simpan Perubahan";
      openModal("item-modal");
    } catch (err) {
      console.error("[openEditModal] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  document.getElementById("modal-close")?.addEventListener("click", () => closeModal("item-modal"));
  document.getElementById("modal-cancel")?.addEventListener("click", () => closeModal("item-modal"));

  // ─── Submit Create / Update ───────────────────────────────────────
  document.getElementById("modal-save")?.addEventListener("click", async () => {
    hideFormError();

    const id = (document.getElementById("item-id") as HTMLInputElement).value;
    const name = (document.getElementById("item-name") as HTMLInputElement).value.trim();
    const category = (document.getElementById("item-category") as HTMLInputElement).value.trim();
    const type = (document.getElementById("item-type") as HTMLSelectElement).value;
    const price = (document.getElementById("item-price") as HTMLInputElement).value;
    const oldPrice = (document.getElementById("item-old-price") as HTMLInputElement).value;
    const badge = (document.getElementById("item-badge") as HTMLSelectElement).value;
    const description = (document.getElementById("item-desc") as HTMLTextAreaElement).value.trim();
    const isActive = (document.getElementById("item-status") as HTMLSelectElement).value === "active";
    const images = getImagesFromForm();
    const variants = getVariantsFromForm();

    // Validasi dasar di client — validasi penuh & otoritatif tetap di
    // backend (lihat validateInventoryInput di inventoryController.js),
    // ini cuma supaya admin tidak perlu menunggu round-trip network
    // untuk kesalahan yang jelas-jelas terlihat dari form.
    if (!name || !category || !price || !description) {
      showFormError("Nama, kategori, harga, dan deskripsi wajib diisi.");
      return;
    }
    if (images.length === 0) {
      showFormError("Minimal 1 foto (URL) wajib diisi.");
      return;
    }
    if (variants.length === 0) {
      showFormError("Minimal 1 varian wajib diisi.");
      return;
    }

    const payload = {
      name,
      category,
      type,
      price: Number(price),
      oldPrice: oldPrice ? Number(oldPrice) : null,
      badge: badge || null,
      description,
      isActive,
      images,
      variants,
    };

    const saveBtn = document.getElementById("modal-save") as HTMLButtonElement;
    const originalLabel = saveBtn.textContent;
    saveBtn.disabled = true;
    saveBtn.textContent = "Menyimpan…";

    try {
      const res = await adminApiFetch(
        id ? `${apiUrl}/api/inventory/${id}` : `${apiUrl}/api/inventory`,
        {
          method: id ? "PATCH" : "POST",
          body: JSON.stringify(payload),
        }
      );
      const json = await res.json();

      if (!res.ok) {
        showFormError(json.error ?? "Gagal menyimpan barang.");
        return;
      }

      window.showToast?.(json.message ?? "Barang berhasil disimpan");
      closeModal("item-modal");
      await loadInventory();
    } catch (err) {
      console.error("[modal-save] gagal fetch backend:", err);
      showFormError("Tidak bisa terhubung ke server. Coba lagi.");
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = originalLabel;
    }
  });

  // ─── Delete ────────────────────────────────────────────────────
  document.getElementById("delete-cancel")?.addEventListener("click", () => {
    itemBeingDeleted = null;
    closeModal("delete-modal");
  });

  document.getElementById("delete-confirm")?.addEventListener("click", async () => {
    if (!itemBeingDeleted) return;

    const confirmBtn = document.getElementById("delete-confirm") as HTMLButtonElement;
    const originalLabel = confirmBtn.textContent;
    confirmBtn.disabled = true;
    confirmBtn.textContent = "Menghapus…";

    try {
      const res = await adminApiFetch(`${apiUrl}/api/inventory/${itemBeingDeleted.id}`, {
        method: "DELETE",
      });
      const json = await res.json();

      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal menghapus barang", "error");
        return;
      }

      window.showToast?.(json.message ?? "Barang dihapus");
      closeModal("delete-modal");
      await loadInventory();
    } catch (err) {
      console.error("[delete-confirm] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    } finally {
      itemBeingDeleted = null;
      confirmBtn.disabled = false;
      confirmBtn.textContent = originalLabel;
    }
  });

  // ─── Export PDF ────────────────────────────────────────────────
  document.getElementById("btn-export-pdf")?.addEventListener("click", () => {
    exportTableToPDF("inventory-table", {
      title: "Daftar Inventory",
      subtitle: "Katalog barang FIREPRO",
    });
  });

  // ─── Init ──────────────────────────────────────────────────────
  loadInventory();
</script>