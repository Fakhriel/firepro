---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<DashboardLayout title="Pengaturan" activeNav="settings">
  <PageHeader heading="Pengaturan" sub="Konfigurasi akun dan preferensi" crumbs={[{ label: "Pengaturan" }]} />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Sidebar menu setting -->
    <div class="lg:col-span-1">
      <nav class="panel overflow-hidden">
        <button
          type="button"
          data-tab="profile"
          class="setting-tab w-full text-left px-4 py-3.5 font-body text-sm font-semibold flex items-center gap-3 border-b border-hairline transition-colors active-tab"
        >
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          Profil Admin
        </button>
        <button
          type="button"
          data-tab="password"
          class="setting-tab w-full text-left px-4 py-3.5 font-body text-sm font-medium flex items-center gap-3 border-b border-hairline transition-colors text-smoke hover:text-ink"
        >
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
            <rect x="3" y="11" width="18" height="11" rx="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Ganti Password
        </button>
        <button
          type="button"
          data-tab="store"
          class="setting-tab w-full text-left px-4 py-3.5 font-body text-sm font-medium flex items-center gap-3 transition-colors text-smoke hover:text-ink"
        >
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
          Info Toko
        </button>
      </nav>
    </div>

    <!-- Content panel -->
    <div class="lg:col-span-2">

      <!-- Tab: Profil Admin -->
      <div id="tab-profile" class="panel">
        <div class="px-5 py-4 border-b-2 border-ink">
          <h3 class="font-display text-xl text-ink leading-none">Profil Admin</h3>
          <p class="font-mono text-[10px] text-smoke mt-1 uppercase tracking-wide">Data akun yang sedang login</p>
        </div>
        <div class="p-5 space-y-4">
          <div class="flex items-center gap-4 p-4 border-2 border-hairline mb-2">
            <div id="profile-avatar" class="w-12 h-12 bg-signal flex items-center justify-center font-display text-paper text-xl shrink-0">A</div>
            <div>
              <p id="profile-name" class="font-semibold text-ink text-base">—</p>
              <p id="profile-role" class="font-mono text-[10px] text-smoke uppercase tracking-widest">—</p>
            </div>
          </div>
          <div>
            <label class="field-label" for="profile-display-name">Nama Tampilan</label>
            <input id="profile-display-name" type="text" class="field-input" />
          </div>
          <div>
            <label class="field-label">Username</label>
            <input id="profile-username-display" type="text" class="field-input bg-hairline/30 cursor-not-allowed" disabled />
            <p class="font-mono text-[9px] text-smoke mt-1">Username tidak bisa diubah sementara.</p>
          </div>
        </div>
        <div class="px-5 py-4 border-t border-hairline flex justify-end">
          <button type="button" id="save-profile" class="btn-primary text-sm">Simpan Perubahan</button>
        </div>
      </div>

      <!-- Tab: Ganti Password -->
      <div id="tab-password" class="panel hidden">
        <div class="px-5 py-4 border-b-2 border-ink">
          <h3 class="font-display text-xl text-ink leading-none">Ganti Password</h3>
          <p class="font-mono text-[10px] text-smoke mt-1 uppercase tracking-wide">Ubah password akun kamu</p>
        </div>
        <div class="p-5 space-y-4">
          <div id="pw-error-inline" class="hidden border-2 border-signal bg-signal/5 px-3 py-2.5">
            <p id="pw-error-inline-msg" class="font-mono text-xs text-signal"></p>
          </div>
          <div>
            <label class="field-label" for="settings-pw-current">Password Sekarang</label>
            <input id="settings-pw-current" type="password" placeholder="••••••••" autocomplete="current-password" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="settings-pw-new">Password Baru</label>
            <input id="settings-pw-new" type="password" placeholder="Min. 8 karakter" autocomplete="new-password" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="settings-pw-confirm">Konfirmasi Password</label>
            <input id="settings-pw-confirm" type="password" placeholder="Ulangi password baru" autocomplete="new-password" class="field-input" />
          </div>
        </div>
        <div class="px-5 py-4 border-t border-hairline flex justify-end">
          <button type="button" id="save-password" class="btn-primary text-sm">Ubah Password</button>
        </div>
      </div>

      <!-- Tab: Info Toko -->
      <div id="tab-store" class="panel hidden">
        <div class="px-5 py-4 border-b-2 border-ink">
          <h3 class="font-display text-xl text-ink leading-none">Info Toko</h3>
          <p class="font-mono text-[10px] text-smoke mt-1 uppercase tracking-wide">Konfigurasi sistem FIREPRO</p>
        </div>
        <div class="p-5 space-y-4">
          <div>
            <label class="field-label" for="store-name">Nama Toko</label>
            <input id="store-name" type="text" placeholder="FIREPRO — Fire Alarm Control" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="store-email">Email Toko</label>
            <input id="store-email" type="email" placeholder="hello@stride.id" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="store-phone">No. WhatsApp</label>
            <input id="store-phone" type="tel" placeholder="628xxxxxxxxxx" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="store-address">Alamat Gudang</label>
            <textarea id="store-address" rows="3" placeholder="Jl. …" class="field-input resize-none"></textarea>
          </div>
          <div>
            <label class="field-label" for="store-origin-id">RajaOngkir Origin ID</label>
            <input id="store-origin-id" type="text" placeholder="501" class="field-input" />
            <p class="font-mono text-[9px] text-smoke mt-1">ID kecamatan gudang untuk kalkulasi ongkir.</p>
          </div>
        </div>
        <div class="px-5 py-4 border-t border-hairline flex justify-end">
          <button type="button" id="save-store" class="btn-primary text-sm">Simpan Info Toko</button>
        </div>
      </div>

    </div>
  </div>
</DashboardLayout>

<style>
  .setting-tab.active-tab {
    color: var(--color-ink);
    background-color: rgba(18,18,18,0.04);
    font-weight: 600;
    border-left: 3px solid var(--color-signal);
  }
</style>

<script>
  import { getAdminAuth, adminApiFetch, API_URL } from "../lib/auth";

  // ─── Populate profile ─────────────────────────────────
  const { admin } = getAdminAuth();
  if (admin) {
    const avatar = document.getElementById("profile-avatar");
    const name = document.getElementById("profile-name");
    const role = document.getElementById("profile-role");
    const nameInput = document.getElementById("profile-display-name") as HTMLInputElement;
    const usernameInput = document.getElementById("profile-username-display") as HTMLInputElement;

    if (avatar) avatar.textContent = admin.name.charAt(0).toUpperCase();
    if (name) name.textContent = admin.name;
    if (role) role.textContent = admin.role === "superadmin" ? "Superadmin" : "Admin";
    if (nameInput) nameInput.value = admin.name;
    if (usernameInput) usernameInput.value = admin.username;
  }

  // ─── Tab switching ────────────────────────────────────
  const tabs = document.querySelectorAll<HTMLButtonElement>(".setting-tab");
  const panels = ["profile", "password", "store"];

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const target = tab.dataset.tab ?? "profile";

      tabs.forEach((t) => t.classList.remove("active-tab"));
      tab.classList.add("active-tab");

      panels.forEach((p) => {
        document.getElementById(`tab-${p}`)?.classList.toggle("hidden", p !== target);
      });
    });
  });

  // ─── Save profile (stub) ──────────────────────────────
  document.getElementById("save-profile")?.addEventListener("click", () => {
    window.showToast?.("Profil berhasil disimpan");
  });

  // ─── Change password (self-service) ───────────────────
  document.getElementById("save-password")?.addEventListener("click", async () => {
    const currentInput = document.getElementById("settings-pw-current") as HTMLInputElement;
    const newInput = document.getElementById("settings-pw-new") as HTMLInputElement;
    const confirmInput = document.getElementById("settings-pw-confirm") as HTMLInputElement;
    const errorBox = document.getElementById("pw-error-inline");
    const errorMsg = document.getElementById("pw-error-inline-msg");
    const saveBtn = document.getElementById("save-password") as HTMLButtonElement;

    errorBox?.classList.add("hidden");

    const currentPassword = currentInput.value;
    const newPassword = newInput.value;
    const confirmPassword = confirmInput.value;

    if (newPassword !== confirmPassword) {
      if (errorMsg) errorMsg.textContent = "Konfirmasi password baru tidak cocok.";
      errorBox?.classList.remove("hidden");
      return;
    }

    if (!admin) {
      window.showToast?.("Sesi login tidak ditemukan, silakan login ulang", "error");
      return;
    }

    saveBtn.disabled = true;
    try {
      const res = await adminApiFetch(`${API_URL}/api/admins/${admin.id}/password`, {
        method: "PATCH",
        body: JSON.stringify({ currentPassword, newPassword, confirmPassword }),
      });
      const json = await res.json().catch(() => ({}));

      if (!res.ok) {
        if (errorMsg) errorMsg.textContent = json.error ?? "Gagal mengganti password.";
        errorBox?.classList.remove("hidden");
        return;
      }

      window.showToast?.("Password berhasil diganti");
      currentInput.value = "";
      newInput.value = "";
      confirmInput.value = "";
    } catch {
      if (errorMsg) errorMsg.textContent = "Tidak bisa terhubung ke server.";
      errorBox?.classList.remove("hidden");
    } finally {
      saveBtn.disabled = false;
    }
  });

  // ─── Save store info (stub) ───────────────────────────
  document.getElementById("save-store")?.addEventListener("click", () => {
    window.showToast?.("Info toko berhasil disimpan");
  });
</script>