---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import StatCard from "../components/StatCard.astro";
---

<DashboardLayout title="Overview" activeNav="overview">
  <PageHeader heading="Overview" sub="Ringkasan performa toko hari ini" />

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <StatCard label="Total Revenue" accent />
    <StatCard label="Total Order" />
    <StatCard label="Produk Aktif" />
    <StatCard label="Pelanggan" />
  </div>

  <!-- 2 col grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6 mb-6">

    <!-- Revenue chart placeholder -->
    <div class="panel lg:col-span-2">
      <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink">
        <div>
          <h3 class="font-display text-lg text-ink leading-none">Revenue</h3>
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">30 hari terakhir</p>
        </div>
        <span class="font-mono text-[10px] text-smoke border border-hairline px-2 py-1">Chart coming soon</span>
      </div>
      <div class="empty-state min-h-52">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
        <p>Data revenue akan tampil di sini</p>
      </div>
    </div>

    <!-- Top produk placeholder -->
    <div class="panel">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Top Produk</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Penjualan tertinggi</p>
      </div>
      <div class="empty-state min-h-52">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
        </svg>
        <p>Belum ada data produk</p>
      </div>
    </div>
  </div>

  <!-- Recent orders placeholder -->
  <div class="panel">
    <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink">
      <div>
        <h3 class="font-display text-lg text-ink leading-none">Order Terbaru</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Transaksi masuk</p>
      </div>
      <a href="/projects" class="btn-secondary text-xs px-3 py-1.5">Lihat Semua</a>
    </div>
    <div class="empty-state min-h-44">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M5.5 8H18.5L19.5 21H4.5L5.5 8Z"/>
        <path d="M8.5 8V6C8.5 4.067 9.567 3 12 3C14.433 3 15.5 4.067 15.5 6V8"/>
      </svg>
      <p>Belum ada order masuk</p>
    </div>
  </div>
</DashboardLayout>