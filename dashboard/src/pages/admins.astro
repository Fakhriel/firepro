---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<DashboardLayout title="Admin" activeNav="admins">
  <PageHeader heading="Admin" sub="Kelola akun admin dashboard" crumbs={[{ label: "Pengguna" }, { label: "Admin" }]}>
    <button id="btn-add-admin" type="button" class="btn-primary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Tambah Admin
    </button>
  </PageHeader>

  <div class="panel overflow-hidden mb-6">
    <div class="overflow-x-auto">
      <table id="admins-table" class="data-table">
        <thead>
          <tr>
            <th class="w-10">#</th>
            <th>Nama</th>
            <th class="hidden sm:table-cell">Username</th>
            <th>Role</th>
            <th class="text-right">Aksi</th>
          </tr>
        </thead>
        <tbody id="admins-body"></tbody>
      </table>
    </div>
    <div id="admins-empty" class="empty-state min-h-44 hidden">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <p>Belum ada akun admin lain</p>
    </div>
  </div>

  <!-- Modal: Ganti Password -->
  <div id="pw-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-ink/50">
    <div class="bg-paper border-2 border-ink w-full max-w-sm brutal-shadow">
      <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink">
        <div>
          <h2 class="font-display text-xl text-ink">Ganti Password</h2>
          <p id="pw-modal-subtitle" class="font-mono text-[10px] text-smoke mt-0.5"></p>
        </div>
        <button id="pw-modal-close" type="button" class="text-smoke hover:text-ink p-1">
          <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <div class="p-5 space-y-4">
        <input type="hidden" id="pw-target-id" />

        <!-- Cuma tampil kalau ganti password punya SENDIRI — reset
             password admin lain (superadmin) tidak butuh ini karena
             mustahil tau password lama orang lain. -->
        <div id="pw-current-wrap">
          <label class="field-label" for="pw-current">Password Sekarang</label>
          <input id="pw-current" type="password" placeholder="••••••••" autocomplete="current-password" class="field-input" />
        </div>
        <div>
          <label class="field-label" for="pw-new">Password Baru</label>
          <input id="pw-new" type="password" placeholder="Min. 8 karakter" autocomplete="new-password" class="field-input" />
        </div>
        <div>
          <label class="field-label" for="pw-confirm">Konfirmasi Password</label>
          <input id="pw-confirm" type="password" placeholder="Ulangi password baru" autocomplete="new-password" class="field-input" />
        </div>

        <div id="pw-error" class="hidden border-2 border-signal bg-signal/5 px-3 py-2">
          <p id="pw-error-msg" class="font-mono text-xs text-signal"></p>
        </div>
      </div>

      <div class="flex gap-3 px-5 py-4 border-t border-hairline">
        <button id="pw-modal-cancel" type="button" class="btn-secondary text-sm flex-1">Batal</button>
        <button id="pw-modal-save" type="button" class="btn-primary text-sm flex-1">Simpan</button>
      </div>
    </div>
  </div>

  <!-- Modal: Tambah Admin -->
  <div id="admin-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-ink/50">
    <div class="bg-paper border-2 border-ink w-full max-w-sm brutal-shadow">
      <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink">
        <h2 class="font-display text-xl text-ink">Tambah Admin</h2>
        <button id="admin-modal-close" type="button" class="text-smoke hover:text-ink p-1">
          <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="p-5 space-y-4">
        <div>
          <label class="field-label" for="new-admin-name">Nama Lengkap</label>
          <input id="new-admin-name" type="text" placeholder="Nama Admin" class="field-input" />
        </div>
        <div>
          <label class="field-label" for="new-admin-username">Username</label>
          <input id="new-admin-username" type="text" placeholder="username" class="field-input" />
        </div>
        <div>
          <label class="field-label" for="new-admin-role">Role</label>
          <select id="new-admin-role" class="field-input">
            <option value="admin">Admin</option>
            <option value="superadmin">Superadmin</option>
          </select>
        </div>
        <div>
          <label class="field-label" for="new-admin-pw">Password Awal</label>
          <input id="new-admin-pw" type="password" placeholder="Min. 8 karakter" class="field-input" />
        </div>

        <div id="admin-modal-error" class="hidden border-2 border-signal bg-signal/5 px-3 py-2">
          <p id="admin-modal-error-msg" class="font-mono text-xs text-signal"></p>
        </div>
      </div>
      <div class="flex gap-3 px-5 py-4 border-t border-hairline">
        <button id="admin-modal-cancel" type="button" class="btn-secondary text-sm flex-1">Batal</button>
        <button id="admin-modal-save" type="button" class="btn-primary text-sm flex-1">Simpan</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { adminApiFetch, getAdminAuth } from "../lib/auth";
  import { escapeHtml } from "../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface AdminAccount {
    id: number;
    username: string;
    name: string;
    role: "admin" | "superadmin";
    createdAt: string;
  }

  const { admin: currentAdmin } = getAdminAuth();
  const currentAdminId = currentAdmin ? Number(currentAdmin.id) : null;

  let allAdmins: AdminAccount[] = [];

  const tableBody = document.getElementById("admins-body") as HTMLTableSectionElement;
  const emptyState = document.getElementById("admins-empty") as HTMLDivElement;
  const table = document.getElementById("admins-table") as HTMLTableElement;

  function openModal(id: string) { document.getElementById(id)?.classList.replace("hidden", "flex"); }
  function closeModal(id: string) { document.getElementById(id)?.classList.replace("flex", "hidden"); }

  function initialOf(name: string): string {
    return (name.trim().charAt(0) || "?").toUpperCase();
  }

  function renderTable(admins: AdminAccount[]): void {
    tableBody.innerHTML = "";

    const isEmpty = admins.length === 0;
    table.classList.toggle("hidden", isEmpty);
    emptyState.classList.toggle("hidden", !isEmpty);

    admins.forEach((a, index) => {
      const isSelf = a.id === currentAdminId;
      const isSuperadmin = a.role === "superadmin";
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="font-mono text-xs text-smoke">${index + 1}</td>
        <td>
          <div class="flex items-center gap-2.5">
            <div class="w-7 h-7 ${isSuperadmin ? "bg-signal" : "bg-ink"} flex items-center justify-center font-display text-paper text-xs shrink-0">${escapeHtml(initialOf(a.name))}</div>
            <span class="font-semibold text-ink">${escapeHtml(a.name)}${isSelf ? ' <span class="font-mono text-[9px] text-smoke">(Anda)</span>' : ""}</span>
          </div>
        </td>
        <td class="hidden sm:table-cell font-mono text-xs text-charcoal">${escapeHtml(a.username)}</td>
        <td>
          <select class="role-select field-input !py-1 !text-xs !w-32" data-id="${a.id}" ${isSelf ? "disabled title=\"Tidak bisa ubah role sendiri\"" : ""}>
            <option value="admin" ${a.role === "admin" ? "selected" : ""}>Admin</option>
            <option value="superadmin" ${a.role === "superadmin" ? "selected" : ""}>Superadmin</option>
          </select>
        </td>
        <td class="text-right whitespace-nowrap">
          <button type="button" data-id="${a.id}" data-name="${escapeHtml(a.name)}" data-self="${isSelf}" class="btn-change-pw text-xs text-smoke hover:text-ink font-mono underline-offset-2 hover:underline mr-3">
            Ganti Password
          </button>
          <button type="button" data-id="${a.id}" data-name="${escapeHtml(a.name)}" class="btn-delete-admin text-xs text-smoke hover:text-signal font-mono underline-offset-2 hover:underline" ${isSelf ? "disabled title=\"Tidak bisa hapus akun sendiri\"" : ""}>
            Hapus
          </button>
        </td>
      `;
      tableBody.appendChild(tr);
    });

    tableBody.querySelectorAll<HTMLSelectElement>(".role-select").forEach((sel) => {
      sel.addEventListener("change", async () => {
        const id = sel.dataset.id;
        const role = sel.value;
        sel.disabled = true;
        try {
          const res = await adminApiFetch(`${apiUrl}/api/admins/${id}`, {
            method: "PATCH",
            body: JSON.stringify({ role }),
          });
          const json = await res.json();
          if (!res.ok) {
            window.showToast?.(json.error ?? "Gagal mengubah role", "error");
            await loadAdmins();
            return;
          }
          window.showToast?.("Role berhasil diubah");
          await loadAdmins();
        } catch {
          window.showToast?.("Tidak bisa terhubung ke server", "error");
        } finally {
          sel.disabled = false;
        }
      });
    });

    tableBody.querySelectorAll<HTMLButtonElement>(".btn-delete-admin").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.dataset.id;
        const name = btn.dataset.name ?? "";
        if (!window.confirm(`Hapus akun admin "${name}"? Aksi ini tidak bisa dibatalkan.`)) return;
        try {
          const res = await adminApiFetch(`${apiUrl}/api/admins/${id}`, { method: "DELETE" });
          const json = await res.json().catch(() => ({}));
          if (!res.ok) {
            window.showToast?.(json.error ?? "Gagal menghapus admin", "error");
            return;
          }
          window.showToast?.("Admin berhasil dihapus");
          await loadAdmins();
        } catch {
          window.showToast?.("Tidak bisa terhubung ke server", "error");
        }
      });
    });

    tableBody.querySelectorAll<HTMLButtonElement>(".btn-change-pw").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.id ?? "";
        const name = btn.dataset.name ?? "";
        const isSelf = btn.dataset.self === "true";

        (document.getElementById("pw-target-id") as HTMLInputElement).value = id;
        (document.getElementById("pw-modal-subtitle") as HTMLElement).textContent = isSelf
          ? "Password akun kamu sendiri"
          : `Reset password — ${name}`;
        (document.getElementById("pw-current") as HTMLInputElement).value = "";
        (document.getElementById("pw-new") as HTMLInputElement).value = "";
        (document.getElementById("pw-confirm") as HTMLInputElement).value = "";
        document.getElementById("pw-error")?.classList.add("hidden");

        document.getElementById("pw-current-wrap")?.classList.toggle("hidden", !isSelf);

        openModal("pw-modal");
      });
    });
  }

  async function loadAdmins(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/admins`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat data admin", "error");
        return;
      }
      allAdmins = json.data ?? [];
      renderTable(allAdmins);
    } catch (err) {
      console.error("[loadAdmins] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  document.getElementById("btn-add-admin")?.addEventListener("click", () => {
    (document.getElementById("new-admin-name") as HTMLInputElement).value = "";
    (document.getElementById("new-admin-username") as HTMLInputElement).value = "";
    (document.getElementById("new-admin-role") as HTMLSelectElement).value = "admin";
    (document.getElementById("new-admin-pw") as HTMLInputElement).value = "";
    document.getElementById("admin-modal-error")?.classList.add("hidden");
    openModal("admin-modal");
  });
  document.getElementById("admin-modal-close")?.addEventListener("click", () => closeModal("admin-modal"));
  document.getElementById("admin-modal-cancel")?.addEventListener("click", () => closeModal("admin-modal"));

  document.getElementById("admin-modal-save")?.addEventListener("click", async () => {
    const name = (document.getElementById("new-admin-name") as HTMLInputElement).value.trim();
    const username = (document.getElementById("new-admin-username") as HTMLInputElement).value.trim();
    const role = (document.getElementById("new-admin-role") as HTMLSelectElement).value;
    const password = (document.getElementById("new-admin-pw") as HTMLInputElement).value;

    const errorBox = document.getElementById("admin-modal-error");
    const errorMsg = document.getElementById("admin-modal-error-msg");

    try {
      const res = await adminApiFetch(`${apiUrl}/api/admins`, {
        method: "POST",
        body: JSON.stringify({ name, username, role, password }),
      });
      const json = await res.json();
      if (!res.ok) {
        if (errorMsg) errorMsg.textContent = json.error ?? "Gagal menambah admin";
        errorBox?.classList.remove("hidden");
        return;
      }
      window.showToast?.("Admin berhasil ditambahkan");
      closeModal("admin-modal");
      await loadAdmins();
    } catch {
      if (errorMsg) errorMsg.textContent = "Tidak bisa terhubung ke server";
      errorBox?.classList.remove("hidden");
    }
  });

  document.getElementById("pw-modal-close")?.addEventListener("click", () => closeModal("pw-modal"));
  document.getElementById("pw-modal-cancel")?.addEventListener("click", () => closeModal("pw-modal"));

  document.getElementById("pw-modal-save")?.addEventListener("click", async () => {
    const id = (document.getElementById("pw-target-id") as HTMLInputElement).value;
    const isSelfChange = !document.getElementById("pw-current-wrap")?.classList.contains("hidden");
    const currentPassword = (document.getElementById("pw-current") as HTMLInputElement).value;
    const newPassword = (document.getElementById("pw-new") as HTMLInputElement).value;
    const confirmPassword = (document.getElementById("pw-confirm") as HTMLInputElement).value;

    const errorBox = document.getElementById("pw-error");
    const errorMsg = document.getElementById("pw-error-msg");

    if (newPassword !== confirmPassword) {
      if (errorMsg) errorMsg.textContent = "Konfirmasi password tidak cocok.";
      errorBox?.classList.remove("hidden");
      return;
    }

    const body: Record<string, string> = { newPassword, confirmPassword };
    if (isSelfChange) body.currentPassword = currentPassword;

    try {
      const res = await adminApiFetch(`${apiUrl}/api/admins/${id}/password`, {
        method: "PATCH",
        body: JSON.stringify(body),
      });
      const json = await res.json();
      if (!res.ok) {
        if (errorMsg) errorMsg.textContent = json.error ?? "Gagal mengganti password";
        errorBox?.classList.remove("hidden");
        return;
      }
      window.showToast?.("Password berhasil diganti");
      closeModal("pw-modal");
    } catch {
      if (errorMsg) errorMsg.textContent = "Tidak bisa terhubung ke server";
      errorBox?.classList.remove("hidden");
    }
  });

  loadAdmins();
</script>