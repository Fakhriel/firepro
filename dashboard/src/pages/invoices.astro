---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<DashboardLayout title="Invoices" activeNav="invoices">
  <PageHeader heading="Invoices" sub="Rekap tagihan &amp; pembayaran proyek" crumbs={[{ label: "Operasional" }, { label: "Invoices" }]}>
    <button id="btn-export-invoices" type="button" class="btn-secondary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="1.75">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/>
        <line x1="9" y1="15" x2="15" y2="15"/>
      </svg>
      Export PDF
    </button>
  </PageHeader>

  <!-- Filter -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <input id="search-invoices" type="search" placeholder="Cari no. invoice / ID proyek…" class="field-input sm:max-w-xs" />
    <select id="filter-invoice-status" class="field-input sm:w-36">
      <option value="">Semua Status</option>
      <option value="paid">Lunas</option>
      <option value="pending">Pending</option>
      <option value="expired">Jatuh Tempo</option>
      <option value="failed">Ditolak</option>
      <option value="cancelled">Dibatalkan</option>
    </select>
  </div>

  <!-- Table -->
  <div class="panel overflow-hidden">
    <div class="overflow-x-auto">
      <table id="invoices-table" class="data-table">
        <thead>
          <tr>
            <th>No. Invoice</th>
            <th class="hidden sm:table-cell">Project ID</th>
            <th>Metode</th>
            <th>Jumlah</th>
            <th class="hidden md:table-cell">Tanggal</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="invoices-body"></tbody>
      </table>
    </div>
    <div id="invoices-empty" class="empty-state min-h-56">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="1" y="4" width="22" height="16" rx="2"/>
        <line x1="1" y1="10" x2="23" y2="10"/>
      </svg>
      <p>Belum ada data invoice</p>
    </div>
    <div class="flex items-center justify-between px-4 py-3 border-t border-hairline">
      <span data-invoices-count class="font-mono text-[10px] text-smoke">0 invoice</span>
      <div class="flex items-center gap-1">
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>←</button>
        <span class="font-mono text-xs px-3 py-1.5 border border-hairline">1</span>
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>→</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { exportTableToPDF } from "../lib/export";
  import { adminApiFetch } from "../lib/auth";
  import { escapeHtml } from "../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface AdminInvoice {
    invoiceNumber: string | null;
    projectId: string;
    amount: number;
    status: string;
    issuedDate: string;
    clientName: string;
  }

  let allInvoices: AdminInvoice[] = [];

  const tbody = document.getElementById("invoices-body") as HTMLTableSectionElement;
  const emptyState = document.getElementById("invoices-empty") as HTMLDivElement;
  const countLabel = document.querySelector<HTMLSpanElement>("[data-invoices-count]");
  const table = document.getElementById("invoices-table") as HTMLTableElement;

  const STATUS_LABELS: Record<string, string> = {
    pending: "Pending",
    paid: "Lunas",
    failed: "Ditolak",
    expired: "Jatuh Tempo",
    cancelled: "Dibatalkan",
  };
  const STATUS_CLASSES: Record<string, string> = {
    pending: "border-ink text-ink",
    paid: "border-armed bg-armed text-paper",
    failed: "border-signal text-signal",
    expired: "border-amber text-amber",
    cancelled: "border-smoke text-smoke",
  };

  function formatRupiah(value: number): string {
    return new Intl.NumberFormat("id-ID", {
      style: "currency", currency: "IDR", minimumFractionDigits: 0,
    }).format(value);
  }
  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString("id-ID", {
      day: "2-digit", month: "short", year: "numeric",
    });
  }

  function renderTable(invoices: AdminInvoice[]): void {
    tbody.innerHTML = "";
    const isEmpty = invoices.length === 0;
    table.classList.toggle("hidden", isEmpty);
    emptyState.classList.toggle("hidden", !isEmpty);
    if (countLabel) countLabel.textContent = `${invoices.length} invoice`;

    invoices.forEach((inv) => {
      const statusLabel = STATUS_LABELS[inv.status] ?? inv.status;
      const statusClass = STATUS_CLASSES[inv.status] ?? "border-smoke text-smoke";
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="font-mono text-xs break-all">${escapeHtml(inv.invoiceNumber ?? "—")}</td>
        <td class="hidden sm:table-cell font-mono text-xs text-smoke">${escapeHtml(inv.projectId)}</td>
        <td class="font-mono text-xs text-smoke">Transfer Bank</td>
        <td class="font-mono text-xs">${formatRupiah(inv.amount)}</td>
        <td class="hidden md:table-cell font-mono text-xs text-smoke">${formatDate(inv.issuedDate)}</td>
        <td>
          <span class="font-mono text-[10px] uppercase tracking-wide px-2 py-0.5 border-2 ${statusClass}">
            ${statusLabel}
          </span>
        </td>
      `;
      tbody.appendChild(tr);
    });
  }

  function applyFilters(): void {
    const keyword = (document.getElementById("search-invoices") as HTMLInputElement)?.value
      .trim().toLowerCase() ?? "";
    const status = (document.getElementById("filter-invoice-status") as HTMLSelectElement)?.value ?? "";

    const filtered = allInvoices.filter((inv) => {
      if (keyword && !(inv.invoiceNumber ?? "").toLowerCase().includes(keyword) &&
          !inv.projectId.toLowerCase().includes(keyword)) return false;
      if (status && inv.status !== status) return false;
      return true;
    });
    renderTable(filtered);
  }

  async function loadInvoices(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/invoices/admin`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat data invoice", "error");
        return;
      }
      allInvoices = json.data ?? [];
      applyFilters();
    } catch {
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  document.getElementById("search-invoices")?.addEventListener("input", applyFilters);
  document.getElementById("filter-invoice-status")?.addEventListener("change", applyFilters);

  document.getElementById("btn-export-invoices")?.addEventListener("click", () => {
    exportTableToPDF("invoices-table", { title: "Rekap Invoice", subtitle: "Data tagihan proyek FIREPRO" });
  });

  loadInvoices();
</script>