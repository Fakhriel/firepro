---
import SupervisorLayout from "../../layouts/SupervisorLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatCard from "../../components/StatCard.astro";
---

<SupervisorLayout title="Daily Report" activeNav="daily-report">
  <PageHeader heading="Daily Report" sub="Pantau laporan harian teknisi di lapangan" crumbs={[{ label: "Fokus Lapangan" }, { label: "Daily Report" }]} />

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <StatCard id="stat-reports-today" label="Laporan Hari Ini" accent />
    <StatCard id="stat-reports-reviewed" label="Sudah Ditinjau" />
    <StatCard id="stat-reports-pending" label="Belum Ditinjau" />
    <StatCard id="stat-reports-obstacle" label="Ada Kendala" />
  </div>

  <!-- Filter -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <input id="search-reports" type="search" placeholder="Cari nama teknisi / proyek…" class="field-input sm:max-w-xs" />
    <select id="filter-report-project" class="field-input sm:w-48">
      <option value="">Semua Proyek</option>
    </select>
    <select id="filter-report-status" class="field-input sm:w-44">
      <option value="">Semua Status</option>
      <option value="submitted">Belum Ditinjau</option>
      <option value="reviewed">Sudah Ditinjau</option>
    </select>
  </div>

  <!-- Table -->
  <div class="panel overflow-hidden">
    <div class="overflow-x-auto">
      <table id="report-table" class="data-table">
        <thead>
          <tr>
            <th>Teknisi</th>
            <th class="hidden sm:table-cell">Proyek</th>
            <th class="hidden md:table-cell">Deskripsi Pekerjaan</th>
            <th>Foto</th>
            <th>Status</th>
            <th class="text-right">Aksi</th>
          </tr>
        </thead>
        <tbody id="report-body"></tbody>
      </table>
    </div>
    <div id="report-empty" class="empty-state min-h-56">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
      </svg>
      <p>Belum ada laporan harian dari tim Anda</p>
    </div>
    <div class="flex items-center justify-between px-4 py-3 border-t border-hairline">
      <span data-report-count class="font-mono text-[10px] text-smoke">0 laporan</span>
      <div class="flex items-center gap-1">
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>←</button>
        <span class="font-mono text-xs px-3 py-1.5 border border-hairline">1</span>
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>→</button>
      </div>
    </div>
  </div>

  <!-- Report detail drawer -->
  <div id="report-drawer" class="fixed inset-y-0 right-0 z-50 w-full sm:w-[420px] bg-paper border-l-2 border-ink translate-x-full transition-transform duration-300 ease-out flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink shrink-0">
      <h2 class="font-display text-xl text-ink">Detail Laporan</h2>
      <button id="report-drawer-close" type="button" class="text-smoke hover:text-ink p-1">
        <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="flex-1 overflow-y-auto p-5">
      <div class="empty-state min-h-40">
        <p>Pilih laporan untuk melihat detail</p>
      </div>
      <div class="space-y-4 mt-6">
        <div>
          <label class="field-label" for="report-comment">Komentar / Catatan Tinjauan</label>
          <textarea id="report-comment" rows="3" class="field-input resize-none" placeholder="Tulis catatan untuk teknisi (opsional)…"></textarea>
        </div>
        <button id="btn-mark-reviewed" type="button" class="btn-primary w-full justify-center gap-1.5" style="background-color: var(--color-armed, #1f7a4d); border-color: var(--color-armed, #1f7a4d);">
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="2">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          Tandai Sudah Ditinjau
        </button>
      </div>
    </div>
  </div>
  <div id="report-drawer-overlay" class="fixed inset-0 bg-ink/40 z-40 hidden"></div>
</SupervisorLayout>

<script>
  import { adminApiFetch } from "../../lib/auth";
  import { escapeHtml } from "../../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface DailyReportRow {
    id: string;
    description: string;
    materialsUsed: string;
    obstacle: string;
    status: "submitted" | "reviewed";
    reviewNote: string;
    technician?: { id: number; name: string };
    project?: { id: number; name: string; code: string };
  }

  let allReports: DailyReportRow[] = [];
  let currentReportId: string | null = null;

  const searchInput = document.getElementById("search-reports") as HTMLInputElement | null;
  const projectFilter = document.getElementById("filter-report-project") as HTMLSelectElement | null;
  const statusFilter = document.getElementById("filter-report-status") as HTMLSelectElement | null;
  const tableBody = document.getElementById("report-body") as HTMLTableSectionElement;
  const table = document.getElementById("report-table") as HTMLTableElement;
  const emptyState = document.getElementById("report-empty") as HTMLDivElement;
  const countLabel = document.querySelector("[data-report-count]") as HTMLElement | null;

  const drawer = document.getElementById("report-drawer");
  const overlay = document.getElementById("report-drawer-overlay");
  const drawerTop = drawer?.querySelector(".flex-1.overflow-y-auto > div:first-child") as HTMLElement | null;

  function setStatValue(cardId: string, value: string): void {
    const card = document.getElementById(cardId);
    if (!card) return;
    let valueEl = card.querySelector<HTMLParagraphElement>(".stat-value");
    if (!valueEl) {
      const skeleton = card.querySelector(".animate-pulse")?.parentElement;
      valueEl = document.createElement("p");
      const isAccent = card.classList.contains("bg-ink");
      valueEl.className = `stat-value font-display text-3xl sm:text-4xl leading-none ${isAccent ? "text-paper" : "text-ink"}`;
      if (skeleton) {
        skeleton.replaceWith(valueEl);
      } else {
        card.appendChild(valueEl);
      }
    }
    valueEl.textContent = value;
  }

  function openDrawer(): void {
    drawer?.classList.remove("translate-x-full");
    overlay?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }
  function closeDrawer(): void {
    drawer?.classList.add("translate-x-full");
    overlay?.classList.add("hidden");
    document.body.style.overflow = "";
    currentReportId = null;
  }
  document.getElementById("report-drawer-close")?.addEventListener("click", closeDrawer);
  overlay?.addEventListener("click", closeDrawer);

  function renderTable(): void {
    const keyword = (searchInput?.value ?? "").trim().toLowerCase();
    const projectId = projectFilter?.value ?? "";
    const statusF = statusFilter?.value ?? "";

    const filtered = allReports.filter((r) => {
      if (statusF && r.status !== statusF) return false;
      if (projectId && String(r.project?.id) !== projectId) return false;
      if (
        keyword &&
        !(r.technician?.name ?? "").toLowerCase().includes(keyword) &&
        !(r.project?.name ?? "").toLowerCase().includes(keyword)
      )
        return false;
      return true;
    });

    tableBody.innerHTML = "";
    const isEmpty = filtered.length === 0;
    table.classList.toggle("hidden", isEmpty);
    emptyState.classList.toggle("hidden", !isEmpty);
    if (countLabel) countLabel.textContent = `${filtered.length} laporan`;

    filtered.forEach((r) => {
      const tr = document.createElement("tr");
      tr.className = "cursor-pointer hover:bg-hairline/10";
      const badge =
        r.status === "reviewed"
          ? "bg-hairline/20 text-smoke border-hairline"
          : "bg-signal/10 text-signal border-signal";
      tr.innerHTML = `
        <td class="font-semibold text-ink">${escapeHtml(r.technician?.name ?? "-")}</td>
        <td class="hidden sm:table-cell font-mono text-xs text-charcoal">${escapeHtml(r.project?.name ?? "-")}</td>
        <td class="hidden md:table-cell font-mono text-xs text-charcoal truncate max-w-xs">${escapeHtml(r.description)}</td>
        <td class="font-mono text-xs text-smoke">-</td>
        <td><span class="font-mono text-[9px] uppercase tracking-widest border px-2 py-1 ${badge}">${r.status === "reviewed" ? "Ditinjau" : "Belum Ditinjau"}</span></td>
        <td class="text-right font-mono text-[10px] text-smoke">Lihat →</td>
      `;
      tr.addEventListener("click", () => openReportDrawer(r));
      tableBody.appendChild(tr);
    });
  }

  function updateStats(): void {
    const today = new Date().toISOString().split("T")[0];
    setStatValue("stat-reports-today", String(allReports.length));
    setStatValue("stat-reports-reviewed", String(allReports.filter((r) => r.status === "reviewed").length));
    setStatValue("stat-reports-pending", String(allReports.filter((r) => r.status === "submitted").length));
    setStatValue("stat-reports-obstacle", String(allReports.filter((r) => (r.obstacle ?? "").trim().length > 0).length));
  }

  function openReportDrawer(r: DailyReportRow): void {
    currentReportId = r.id;
    if (drawerTop) {
      drawerTop.innerHTML = `
        <div class="space-y-2">
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest">${escapeHtml(r.project?.code ?? "")}</p>
          <h3 class="font-display text-lg text-ink">${escapeHtml(r.technician?.name ?? "-")}</h3>
          <p class="font-body text-sm text-charcoal">${escapeHtml(r.project?.name ?? "-")}</p>
          <div class="border-t border-hairline pt-3 mt-3 space-y-2">
            <div>
              <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mb-1">Deskripsi Pekerjaan</p>
              <p class="font-body text-sm text-ink">${escapeHtml(r.description)}</p>
            </div>
            ${
              r.materialsUsed
                ? `<div><p class="font-mono text-[9px] text-smoke uppercase tracking-widest mb-1">Material Digunakan</p><p class="font-body text-sm text-ink">${escapeHtml(r.materialsUsed)}</p></div>`
                : ""
            }
            ${
              r.obstacle
                ? `<div><p class="font-mono text-[9px] text-signal uppercase tracking-widest mb-1">Kendala</p><p class="font-body text-sm text-ink">${escapeHtml(r.obstacle)}</p></div>`
                : ""
            }
          </div>
        </div>
      `;
    }
    (document.getElementById("report-comment") as HTMLTextAreaElement).value = r.reviewNote || "";
    openDrawer();
  }

  async function loadReports(): Promise<void> {
    try {
      const params = new URLSearchParams();
      if (statusFilter?.value) params.set("status", statusFilter.value);
      if (projectFilter?.value) params.set("projectId", projectFilter.value);
      const res = await adminApiFetch(`${apiUrl}/api/supervisor/daily-report?${params.toString()}`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat laporan harian", "error");
        return;
      }
      allReports = json.data ?? [];
      renderTable();
      updateStats();
      populateProjectFilter();
    } catch (err) {
      console.error("[loadReports] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  function populateProjectFilter(): void {
    if (!projectFilter || projectFilter.dataset.filled === "true") return;
    const seen = new Map<number, string>();
    allReports.forEach((r) => {
      if (r.project) seen.set(r.project.id, r.project.name);
    });
    if (seen.size === 0) return;
    projectFilter.innerHTML =
      `<option value="">Semua Proyek</option>` +
      Array.from(seen.entries())
        .map(([id, name]) => `<option value="${id}">${escapeHtml(name)}</option>`)
        .join("");
    projectFilter.dataset.filled = "true";
  }

  document.getElementById("btn-mark-reviewed")?.addEventListener("click", async () => {
    if (!currentReportId) return;
    const reviewNote = (document.getElementById("report-comment") as HTMLTextAreaElement).value.trim();
    try {
      const res = await adminApiFetch(`${apiUrl}/api/supervisor/daily-report/${currentReportId}/review`, {
        method: "PATCH",
        body: JSON.stringify({ reviewNote: reviewNote || undefined }),
      });
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal menandai laporan", "error");
        return;
      }
      window.showToast?.(json.message ?? "Laporan ditandai sudah ditinjau");
      closeDrawer();
      await loadReports();
    } catch (err) {
      console.error("[btn-mark-reviewed] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  });

  let searchDebounce: ReturnType<typeof setTimeout>;
  searchInput?.addEventListener("input", () => {
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(renderTable, 300);
  });
  projectFilter?.addEventListener("change", loadReports);
  statusFilter?.addEventListener("change", loadReports);

  loadReports();
</script>
