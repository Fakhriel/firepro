---
import SupervisorLayout from "../../layouts/SupervisorLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatCard from "../../components/StatCard.astro";
---

<SupervisorLayout title="Dashboard" activeNav="dashboard">
  <PageHeader heading="Dashboard" sub="Ringkasan operasional lapangan hari ini" />

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <StatCard id="stat-projects-active" label="Proyek Aktif" accent />
    <StatCard id="stat-pending-approval" label="Menunggu Approval" />
    <StatCard id="stat-technicians-onsite" label="Teknisi Bertugas" />
    <StatCard id="stat-inventory-pending" label="Request Barang Pending" />
  </div>

  <!-- Quick actions -->
  <div class="grid grid-cols-1 sm:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <a href="/supervisor/projects" class="panel flex items-center gap-3 px-5 py-4 hover:brutal-shadow-sm transition-shadow duration-150">
      <div class="w-9 h-9 shrink-0 bg-ink text-paper flex items-center justify-center">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-body text-sm font-semibold text-ink">Assign Teknisi</p>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">Ke Proyek Berjalan</p>
      </div>
    </a>
    <a href="/supervisor/projects" class="panel flex items-center gap-3 px-5 py-4 hover:brutal-shadow-sm transition-shadow duration-150">
      <div class="w-9 h-9 shrink-0 bg-ink text-paper flex items-center justify-center">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
          <circle cx="12" cy="13" r="4"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-body text-sm font-semibold text-ink">Upload Dokumentasi</p>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">Progres Pekerjaan</p>
      </div>
    </a>
    <a href="/supervisor/inventory" class="panel flex items-center gap-3 px-5 py-4 hover:brutal-shadow-sm transition-shadow duration-150">
      <div class="w-9 h-9 shrink-0 bg-ink text-paper flex items-center justify-center">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-body text-sm font-semibold text-ink">Request Barang</p>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">Inventory</p>
      </div>
    </a>
    <a href="/supervisor/projects" class="panel flex items-center gap-3 px-5 py-4 hover:brutal-shadow-sm transition-shadow duration-150">
      <div class="w-9 h-9 shrink-0 bg-ink text-paper flex items-center justify-center">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-body text-sm font-semibold text-ink">Approve Selesai</p>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">Pekerjaan Teknisi</p>
      </div>
    </a>
  </div>

  <!-- 2 col grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">

    <!-- Proyek perlu perhatian -->
    <div class="panel">
      <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink">
        <div>
          <h3 class="font-display text-lg text-ink leading-none">Proyek Perlu Perhatian</h3>
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Progres tertahan / mendekati tenggat</p>
        </div>
        <a href="/supervisor/projects" class="font-mono text-[10px] text-smoke border border-hairline px-2 py-1 hover:text-ink hover:border-ink transition-colors">Lihat Semua</a>
      </div>
      <div id="dashboard-projects-empty" class="empty-state min-h-52">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5.5 8H18.5L19.5 21H4.5L5.5 8Z"/>
          <path d="M8.5 8V6C8.5 4.067 9.567 3 12 3C14.433 3 15.5 4.067 15.5 6V8"/>
        </svg>
        <p>Belum ada proyek yang perlu perhatian</p>
      </div>
      <ul id="dashboard-projects-list" class="hidden divide-y divide-hairline"></ul>
    </div>

    <!-- Approval pekerjaan selesai -->
    <div class="panel">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Menunggu Approval</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Pekerjaan teknisi ditandai selesai</p>
      </div>
      <div id="dashboard-approval-empty" class="empty-state min-h-52">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
        <p>Tidak ada pekerjaan menunggu approval</p>
      </div>
      <ul id="dashboard-approval-list" class="hidden divide-y divide-hairline"></ul>
    </div>
  </div>
</SupervisorLayout>

<script>
  import { adminApiFetch } from "../../lib/auth";
  import { escapeHtml } from "../../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  function setStatValue(cardId: string, value: string): void {
    const card = document.getElementById(cardId);
    if (!card) return;
    let valueEl = card.querySelector<HTMLParagraphElement>(".stat-value");
    if (!valueEl) {
      const skeleton = card.querySelector(".animate-pulse")?.parentElement;
      valueEl = document.createElement("p");
      const isAccent = card.classList.contains("bg-ink");
      valueEl.className = `stat-value font-display text-3xl sm:text-4xl leading-none ${isAccent ? "text-paper" : "text-ink"}`;
      if (skeleton) {
        skeleton.replaceWith(valueEl);
      } else {
        card.appendChild(valueEl);
      }
    }
    valueEl.textContent = value;
  }

  async function loadSummary(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/supervisor/dashboard/summary`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat ringkasan dashboard", "error");
        return;
      }
      const d = json.data ?? {};
      setStatValue("stat-projects-active", String(d.activeProjects ?? 0));
      setStatValue("stat-pending-approval", String(d.pendingReports ?? 0));
      setStatValue("stat-technicians-onsite", String(d.technicians ?? 0));
      setStatValue("stat-inventory-pending", String(d.pendingRequests ?? 0));
    } catch (err) {
      console.error("[loadSummary] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  interface ProjectRow {
    id: number;
    projectCode: string;
    projectName: string;
    clientName: string;
    status: string;
  }

  async function loadAttentionProjects(): Promise<void> {
    const emptyEl = document.getElementById("dashboard-projects-empty");
    const listEl = document.getElementById("dashboard-projects-list") as HTMLUListElement | null;
    if (!listEl) return;
    try {
      const res = await adminApiFetch(`${apiUrl}/api/supervisor/projects?status=in_progress`);
      const json = await res.json();
      if (!res.ok) return;
      const projects: ProjectRow[] = json.data ?? [];
      const isEmpty = projects.length === 0;
      emptyEl?.classList.toggle("hidden", !isEmpty);
      listEl.classList.toggle("hidden", isEmpty);
      listEl.innerHTML = projects
        .slice(0, 6)
        .map(
          (p) => `
        <li class="px-5 py-3 flex items-center justify-between gap-3">
          <div class="min-w-0">
            <p class="font-body text-sm text-ink truncate">${escapeHtml(p.projectName)}</p>
            <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">${escapeHtml(p.projectCode)} — ${escapeHtml(p.clientName)}</p>
          </div>
          <span class="font-mono text-[9px] uppercase tracking-widest border border-ink px-2 py-1 shrink-0">Berjalan</span>
        </li>
      `
        )
        .join("");
    } catch (err) {
      console.error("[loadAttentionProjects] gagal fetch backend:", err);
    }
  }

  interface DailyReportRow {
    id: string;
    description: string;
    reportDate: string;
    technician?: { id: number; name: string };
    project?: { id: number; name: string; code: string };
  }

  async function loadPendingApprovals(): Promise<void> {
    const emptyEl = document.getElementById("dashboard-approval-empty");
    const listEl = document.getElementById("dashboard-approval-list") as HTMLUListElement | null;
    if (!listEl) return;
    try {
      const res = await adminApiFetch(`${apiUrl}/api/supervisor/daily-report?status=submitted`);
      const json = await res.json();
      if (!res.ok) return;
      const reports: DailyReportRow[] = json.data ?? [];
      const isEmpty = reports.length === 0;
      emptyEl?.classList.toggle("hidden", !isEmpty);
      listEl.classList.toggle("hidden", isEmpty);
      listEl.innerHTML = reports
        .slice(0, 6)
        .map(
          (r) => `
        <li class="px-5 py-3 flex items-center justify-between gap-3">
          <div class="min-w-0">
            <p class="font-body text-sm text-ink truncate">${escapeHtml(r.technician?.name ?? "Teknisi")} — ${escapeHtml(r.project?.name ?? "-")}</p>
            <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5 truncate">${escapeHtml(r.description)}</p>
          </div>
          <span class="font-mono text-[9px] uppercase tracking-widest border border-signal text-signal px-2 py-1 shrink-0">Ditinjau</span>
        </li>
      `
        )
        .join("");
    } catch (err) {
      console.error("[loadPendingApprovals] gagal fetch backend:", err);
    }
  }

  loadSummary();
  loadAttentionProjects();
  loadPendingApprovals();
</script>
