---
import SupervisorLayout from "../../layouts/SupervisorLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatCard from "../../components/StatCard.astro";
---

<SupervisorLayout title="Attendance" activeNav="attendance">
  <PageHeader heading="Attendance" sub="Absensi Anda & pantau kehadiran tim lapangan" crumbs={[{ label: "Fokus Lapangan" }, { label: "Attendance" }]} />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6 mb-8">
    <!-- Own check in/out card -->
    <div class="panel lg:col-span-1 flex flex-col items-center text-center px-6 py-8">
      <p class="font-mono text-[10px] uppercase tracking-widest text-smoke mb-2">Waktu Saat Ini</p>
      <p id="live-clock" class="font-display text-4xl text-ink leading-none mb-1">--:--:--</p>
      <p id="live-date" class="font-mono text-xs text-smoke mb-6">—</p>

      <div id="attendance-status-badge" class="badge badge-inactive mb-6">Belum Check In</div>

      <button id="btn-check-in" type="button" class="btn-primary w-full justify-center">
        Check In
      </button>
      <button id="btn-check-out" type="button" class="btn-danger w-full justify-center hidden">
        Check Out
      </button>
    </div>

    <!-- Team summary -->
    <div class="panel lg:col-span-2">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Ringkasan Kehadiran Tim</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">
          {new Date().toLocaleDateString("id-ID", { weekday: "long", day: "numeric", month: "long", year: "numeric" })}
        </p>
      </div>
      <div class="grid grid-cols-3 divide-x divide-hairline">
        <div class="px-5 py-6 text-center">
          <p class="font-mono text-[9px] uppercase tracking-widest text-smoke mb-2">Sudah Check In</p>
          <p id="summary-checked-in" class="font-display text-2xl text-ink">0</p>
        </div>
        <div class="px-5 py-6 text-center">
          <p class="font-mono text-[9px] uppercase tracking-widest text-smoke mb-2">Belum Check In</p>
          <p id="summary-not-in" class="font-display text-2xl text-ink">0</p>
        </div>
        <div class="px-5 py-6 text-center">
          <p class="font-mono text-[9px] uppercase tracking-widest text-smoke mb-2">Sudah Check Out</p>
          <p id="summary-checked-out" class="font-display text-2xl text-ink">0</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Stat cards for personal history -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <StatCard id="stat-attendance-month" label="Hadir Bulan Ini" accent />
    <StatCard id="stat-attendance-late" label="Terlambat" />
    <StatCard id="stat-attendance-absent" label="Tidak Hadir" />
    <StatCard id="stat-attendance-avg-hours" label="Rata-rata Jam Kerja" />
  </div>

  <!-- Team attendance table -->
  <div class="panel overflow-hidden mb-8">
    <div class="px-5 py-4 border-b-2 border-ink">
      <h3 class="font-display text-lg text-ink leading-none">Kehadiran Teknisi Hari Ini</h3>
      <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Tim di bawah pengawasan Anda</p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 px-5 py-4 border-b border-hairline">
      <input id="search-team-attendance" type="search" placeholder="Cari nama teknisi…" class="field-input sm:max-w-xs" />
      <select id="filter-team-attendance" class="field-input sm:w-44">
        <option value="">Semua Status</option>
        <option value="checked_in">Sedang Bekerja</option>
        <option value="checked_out">Sudah Pulang</option>
        <option value="not_in">Belum Check In</option>
      </select>
    </div>
    <div class="overflow-x-auto">
      <table id="team-attendance-table" class="data-table">
        <thead>
          <tr>
            <th>Nama Teknisi</th>
            <th class="hidden sm:table-cell">Proyek</th>
            <th>Jam Masuk</th>
            <th>Jam Keluar</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="team-attendance-body"></tbody>
      </table>
    </div>
    <div id="team-attendance-empty" class="empty-state min-h-52">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
      </svg>
      <p>Belum ada data kehadiran teknisi hari ini</p>
    </div>
  </div>

  <!-- Personal history -->
  <div class="panel overflow-hidden">
    <div class="px-5 py-4 border-b-2 border-ink">
      <h3 class="font-display text-lg text-ink leading-none">Riwayat Kehadiran Saya</h3>
      <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">30 hari terakhir</p>
    </div>
    <div class="overflow-x-auto">
      <table id="attendance-table" class="data-table">
        <thead>
          <tr>
            <th>Tanggal</th>
            <th>Jam Masuk</th>
            <th>Jam Keluar</th>
            <th class="hidden sm:table-cell">Durasi</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="attendance-body"></tbody>
      </table>
    </div>
    <div id="attendance-empty" class="empty-state min-h-52">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 16 14"/>
      </svg>
      <p>Belum ada riwayat kehadiran</p>
    </div>
  </div>
</SupervisorLayout>

<script>
  import { adminApiFetch } from "../../lib/auth";
  import { escapeHtml } from "../../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface AttendanceRecord {
    id: string;
    workDate: string;
    checkInAt: string | null;
    checkOutAt: string | null;
    status: string;
    admin?: { id: number; name: string };
  }
  interface Technician {
    id: number;
    name: string;
  }

  // ─── Live clock ─────────────────────────────────────────────────────
  function tickClock(): void {
    const now = new Date();
    const clockEl = document.getElementById("live-clock");
    const dateEl = document.getElementById("live-date");
    if (clockEl) {
      clockEl.textContent = now.toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
    }
    if (dateEl) {
      dateEl.textContent = now.toLocaleDateString("id-ID", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
    }
  }
  tickClock();
  setInterval(tickClock, 1000);

  function setStatValue(cardId: string, value: string): void {
    const card = document.getElementById(cardId);
    if (!card) return;
    let valueEl = card.querySelector<HTMLParagraphElement>(".stat-value");
    if (!valueEl) {
      const skeleton = card.querySelector(".animate-pulse")?.parentElement;
      valueEl = document.createElement("p");
      const isAccent = card.classList.contains("bg-ink");
      valueEl.className = `stat-value font-display text-3xl sm:text-4xl leading-none ${isAccent ? "text-paper" : "text-ink"}`;
      if (skeleton) {
        skeleton.replaceWith(valueEl);
      } else {
        card.appendChild(valueEl);
      }
    }
    valueEl.textContent = value;
  }

  function formatTime(iso: string | null): string {
    if (!iso) return "-";
    try {
      return new Date(iso).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
    } catch {
      return "-";
    }
  }
  function formatDate(iso: string): string {
    try {
      return new Date(iso).toLocaleDateString("id-ID", { day: "2-digit", month: "short", year: "numeric" });
    } catch {
      return iso;
    }
  }
  function durationHours(checkIn: string | null, checkOut: string | null): number {
    if (!checkIn || !checkOut) return 0;
    const ms = new Date(checkOut).getTime() - new Date(checkIn).getTime();
    return ms > 0 ? ms / 3600000 : 0;
  }
  function formatDuration(checkIn: string | null, checkOut: string | null): string {
    const hrs = durationHours(checkIn, checkOut);
    if (hrs === 0) return "-";
    const h = Math.floor(hrs);
    const m = Math.round((hrs - h) * 60);
    return `${h}j ${m}m`;
  }

  // ─── Absensi milik sendiri ──────────────────────────────────────────
  const btnIn = document.getElementById("btn-check-in");
  const btnOut = document.getElementById("btn-check-out");
  const badge = document.getElementById("attendance-status-badge");

  function applySelfState(record: AttendanceRecord | null): void {
    if (record?.checkOutAt) {
      if (badge) {
        badge.textContent = "Selesai Check Out";
        badge.className = "badge badge-inactive mb-6";
      }
      btnIn?.classList.add("hidden");
      btnOut?.classList.add("hidden");
    } else if (record?.checkInAt) {
      if (badge) {
        badge.textContent = "Sedang Bekerja";
        badge.className = "badge badge-active mb-6";
      }
      btnIn?.classList.add("hidden");
      btnOut?.classList.remove("hidden");
    } else {
      if (badge) {
        badge.textContent = "Belum Check In";
        badge.className = "badge badge-inactive mb-6";
      }
      btnIn?.classList.remove("hidden");
      btnOut?.classList.add("hidden");
    }
  }

  async function loadToday(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/supervisor/attendance/today`);
      const json = await res.json();
      if (!res.ok) return;
      applySelfState(json.data ?? null);
    } catch (err) {
      console.error("[loadToday] gagal fetch backend:", err);
    }
  }

  btnIn?.addEventListener("click", async () => {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/supervisor/attendance/check-in`, { method: "POST", body: JSON.stringify({}) });
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal check in", "error");
        return;
      }
      window.showToast?.(json.message ?? "Check in berhasil");
      applySelfState(json.data);
      await loadHistory();
    } catch (err) {
      console.error("[btn-check-in] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  });

  btnOut?.addEventListener("click", async () => {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/supervisor/attendance/check-out`, { method: "POST", body: JSON.stringify({}) });
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal check out", "error");
        return;
      }
      window.showToast?.(json.message ?? "Check out berhasil");
      applySelfState(json.data);
      await loadHistory();
    } catch (err) {
      console.error("[btn-check-out] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  });

  // ─── Riwayat kehadiran saya ─────────────────────────────────────────
  async function loadHistory(): Promise<void> {
    const tableBody = document.getElementById("attendance-body") as HTMLTableSectionElement;
    const table = document.getElementById("attendance-table") as HTMLTableElement;
    const emptyState = document.getElementById("attendance-empty") as HTMLDivElement;
    try {
      const res = await adminApiFetch(`${apiUrl}/api/supervisor/attendance/history`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat riwayat kehadiran", "error");
        return;
      }
      const history: AttendanceRecord[] = json.data ?? [];
      const isEmpty = history.length === 0;
      table.classList.toggle("hidden", isEmpty);
      emptyState.classList.toggle("hidden", !isEmpty);
      tableBody.innerHTML = history
        .map(
          (r) => `
        <tr>
          <td class="font-mono text-xs text-charcoal">${formatDate(r.workDate)}</td>
          <td class="font-mono text-xs text-charcoal">${formatTime(r.checkInAt)}</td>
          <td class="font-mono text-xs text-charcoal">${formatTime(r.checkOutAt)}</td>
          <td class="hidden sm:table-cell font-mono text-xs text-charcoal">${formatDuration(r.checkInAt, r.checkOutAt)}</td>
          <td><span class="font-mono text-[9px] uppercase tracking-widest border px-2 py-1 ${r.checkOutAt ? "bg-hairline/20 text-smoke border-hairline" : "bg-ink/5 text-ink border-ink"}">${r.checkOutAt ? "Sudah Pulang" : "Sedang Bekerja"}</span></td>
        </tr>
      `
        )
        .join("");

      const now = new Date();
      const thisMonth = history.filter((r) => {
        const d = new Date(r.workDate);
        return d.getFullYear() === now.getFullYear() && d.getMonth() === now.getMonth();
      });
      setStatValue("stat-attendance-month", String(thisMonth.length));
      setStatValue("stat-attendance-late", "0");
      setStatValue("stat-attendance-absent", "0");
      const durations = thisMonth.map((r) => durationHours(r.checkInAt, r.checkOutAt)).filter((h) => h > 0);
      const avg = durations.length ? durations.reduce((a, b) => a + b, 0) / durations.length : 0;
      setStatValue("stat-attendance-avg-hours", avg > 0 ? `${avg.toFixed(1)}j` : "-");
    } catch (err) {
      console.error("[loadHistory] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  // ─── Kehadiran tim (teknisi) hari ini ───────────────────────────────
  interface TeamRow {
    userId: number;
    name: string;
    checkInAt: string | null;
    checkOutAt: string | null;
    status: "checked_in" | "checked_out" | "not_in";
  }
  let teamRows: TeamRow[] = [];
  const teamSearch = document.getElementById("search-team-attendance") as HTMLInputElement | null;
  const teamFilter = document.getElementById("filter-team-attendance") as HTMLSelectElement | null;

  const TEAM_STATUS_LABEL: Record<string, string> = {
    checked_in: "Sedang Bekerja",
    checked_out: "Sudah Pulang",
    not_in: "Belum Check In",
  };
  const TEAM_STATUS_BADGE: Record<string, string> = {
    checked_in: "bg-ink/5 text-ink border-ink",
    checked_out: "bg-hairline/20 text-smoke border-hairline",
    not_in: "bg-signal/10 text-signal border-signal",
  };

  function setPlainValue(id: string, value: string): void {
    const el = document.getElementById(id);
    if (el) el.textContent = value;
  }

  function renderTeamTable(): void {
    const tableBody = document.getElementById("team-attendance-body") as HTMLTableSectionElement;
    const table = document.getElementById("team-attendance-table") as HTMLTableElement;
    const emptyState = document.getElementById("team-attendance-empty") as HTMLDivElement;

    const keyword = (teamSearch?.value ?? "").trim().toLowerCase();
    const statusF = teamFilter?.value ?? "";
    const filtered = teamRows.filter((r) => {
      if (keyword && !r.name.toLowerCase().includes(keyword)) return false;
      if (statusF && r.status !== statusF) return false;
      return true;
    });

    tableBody.innerHTML = "";
    const isEmpty = filtered.length === 0;
    table.classList.toggle("hidden", isEmpty);
    emptyState.classList.toggle("hidden", !isEmpty);

    filtered.forEach((r) => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="font-semibold text-ink">${escapeHtml(r.name)}</td>
        <td class="hidden sm:table-cell font-mono text-xs text-charcoal">-</td>
        <td class="font-mono text-xs text-charcoal">${formatTime(r.checkInAt)}</td>
        <td class="font-mono text-xs text-charcoal">${formatTime(r.checkOutAt)}</td>
        <td><span class="font-mono text-[9px] uppercase tracking-widest border px-2 py-1 ${TEAM_STATUS_BADGE[r.status]}">${TEAM_STATUS_LABEL[r.status]}</span></td>
      `;
      tableBody.appendChild(tr);
    });

    setPlainValue("summary-checked-in", String(teamRows.filter((r) => r.status !== "not_in").length));
    setPlainValue("summary-not-in", String(teamRows.filter((r) => r.status === "not_in").length));
    setPlainValue("summary-checked-out", String(teamRows.filter((r) => r.status === "checked_out").length));
  }

  async function loadTeamAttendance(): Promise<void> {
    try {
      const [techRes, teamRes] = await Promise.all([
        adminApiFetch(`${apiUrl}/api/supervisor/technicians`),
        adminApiFetch(`${apiUrl}/api/supervisor/attendance/team`),
      ]);
      const techJson = await techRes.json();
      const teamJson = await teamRes.json();
      if (!techRes.ok || !teamRes.ok) {
        window.showToast?.(techJson.error ?? teamJson.error ?? "Gagal memuat kehadiran tim", "error");
        return;
      }
      const technicians: Technician[] = techJson.data ?? [];
      const records: AttendanceRecord[] = teamJson.data ?? [];
      const recordByAdminId = new Map(records.map((r) => [r.admin?.id, r]));

      teamRows = technicians.map((t) => {
        const rec = recordByAdminId.get(t.id);
        let status: TeamRow["status"] = "not_in";
        if (rec?.checkOutAt) status = "checked_out";
        else if (rec?.checkInAt) status = "checked_in";
        return { userId: t.id, name: t.name, checkInAt: rec?.checkInAt ?? null, checkOutAt: rec?.checkOutAt ?? null, status };
      });
      renderTeamTable();
    } catch (err) {
      console.error("[loadTeamAttendance] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  teamSearch?.addEventListener("input", renderTeamTable);
  teamFilter?.addEventListener("change", renderTeamTable);

  loadToday();
  loadHistory();
  loadTeamAttendance();
</script>
