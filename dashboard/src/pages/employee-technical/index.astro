---
import EmployeeLayout from "../../layouts/EmployeeLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatCard from "../../components/StatCard.astro";
---

<EmployeeLayout title="Dashboard" activeNav="dashboard">
  <PageHeader heading="Dashboard" sub="Ringkasan aktivitas kerja Anda hari ini" />

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <StatCard id="stat-tasks-today" label="Tugas Hari Ini" accent />
    <StatCard id="stat-attendance-status" label="Status Absensi" />
    <StatCard id="stat-reports-pending" label="Laporan Tertunda" />
    <StatCard id="stat-requests-active" label="Request Alat Aktif" />
  </div>

  <!-- Quick actions -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 mb-8">
    <a href="/employee-technical/attendance" class="panel flex items-center gap-3 px-5 py-4 hover:brutal-shadow-sm transition-shadow duration-150">
      <div class="w-9 h-9 shrink-0 bg-ink text-paper flex items-center justify-center">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
          <circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 16 14"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-body text-sm font-semibold text-ink">Check In / Check Out</p>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">Absensi Hari Ini</p>
      </div>
    </a>
    <a href="/employee-technical/daily-report" class="panel flex items-center gap-3 px-5 py-4 hover:brutal-shadow-sm transition-shadow duration-150">
      <div class="w-9 h-9 shrink-0 bg-ink text-paper flex items-center justify-center">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-body text-sm font-semibold text-ink">Isi Laporan Harian</p>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">Daily Report</p>
      </div>
    </a>
    <a href="/employee-technical/inventory-request" class="panel flex items-center gap-3 px-5 py-4 hover:brutal-shadow-sm transition-shadow duration-150">
      <div class="w-9 h-9 shrink-0 bg-ink text-paper flex items-center justify-center">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="font-body text-sm font-semibold text-ink">Request Alat</p>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">Inventory Request</p>
      </div>
    </a>
  </div>

  <!-- 2 col grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">

    <!-- Tugas hari ini -->
    <div class="panel">
      <div class="flex items-center justify-between px-5 py-4 border-b-2 border-ink">
        <div>
          <h3 class="font-display text-lg text-ink leading-none">Tugas Hari Ini</h3>
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Ditugaskan kepada Anda</p>
        </div>
        <a href="/employee-technical/my-tasks" class="font-mono text-[10px] text-smoke border border-hairline px-2 py-1 hover:text-ink hover:border-ink transition-colors">Lihat Semua</a>
      </div>
      <div id="dashboard-tasks-empty" class="empty-state min-h-52">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 6h11M9 12h11M9 18h11"/>
          <path d="M4.5 6l1 1 2-2M4.5 12l1 1 2-2M4.5 18l1 1 2-2"/>
        </svg>
        <p>Belum ada tugas untuk hari ini</p>
      </div>
      <ul id="dashboard-tasks-list" class="hidden divide-y divide-hairline"></ul>
    </div>

    <!-- Aktivitas terbaru -->
    <div class="panel">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Aktivitas Terbaru</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Riwayat check-in, laporan, request</p>
      </div>
      <div id="dashboard-activity-empty" class="empty-state min-h-52">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 16 14"/>
        </svg>
        <p>Belum ada aktivitas tercatat</p>
      </div>
      <ul id="dashboard-activity-list" class="hidden divide-y divide-hairline"></ul>
    </div>
  </div>
</EmployeeLayout>

<script>
  import { adminApiFetch } from "../../lib/auth";
  import { escapeHtml } from "../../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  function setStatValue(cardId: string, value: string): void {
    const card = document.getElementById(cardId);
    if (!card) return;
    let valueEl = card.querySelector<HTMLParagraphElement>(".stat-value");
    if (!valueEl) {
      const skeleton = card.querySelector(".animate-pulse")?.parentElement;
      valueEl = document.createElement("p");
      const isAccent = card.classList.contains("bg-ink");
      valueEl.className = `stat-value font-display text-3xl sm:text-4xl leading-none ${isAccent ? "text-paper" : "text-ink"}`;
      if (skeleton) {
        skeleton.replaceWith(valueEl);
      } else {
        card.appendChild(valueEl);
      }
    }
    valueEl.textContent = value;
  }

  const ATTENDANCE_STATUS_LABEL: Record<string, string> = {
    not_checked_in: "Belum Check In",
    checked_in: "Sedang Bekerja",
    checked_out: "Sudah Pulang",
  };

  async function loadSummary(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/technical/dashboard/summary`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat ringkasan dashboard", "error");
        return;
      }
      const d = json.data ?? {};
      setStatValue("stat-tasks-today", String(d.tasksActive ?? 0));
      setStatValue("stat-attendance-status", ATTENDANCE_STATUS_LABEL[d.attendanceStatus] ?? "-");
      setStatValue("stat-reports-pending", d.reportSubmittedToday ? "0" : "1");
      setStatValue("stat-requests-active", String(d.requestsPending ?? 0));
    } catch (err) {
      console.error("[loadSummary] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  interface Assignment {
    id: string;
    status: "assigned" | "in_progress" | "done";
    notes: string;
    project?: { id: number; name: string; code: string; location: string };
  }

  const STATUS_LABEL: Record<string, string> = { assigned: "Ditugaskan", in_progress: "Berjalan", done: "Selesai" };

  async function loadTasks(): Promise<void> {
    const emptyEl = document.getElementById("dashboard-tasks-empty");
    const listEl = document.getElementById("dashboard-tasks-list") as HTMLUListElement | null;
    if (!listEl) return;
    try {
      const res = await adminApiFetch(`${apiUrl}/api/technical/tasks`);
      const json = await res.json();
      if (!res.ok) return;
      const tasks: Assignment[] = (json.data ?? []).filter((t: Assignment) => t.status !== "done");
      const isEmpty = tasks.length === 0;
      emptyEl?.classList.toggle("hidden", !isEmpty);
      listEl.classList.toggle("hidden", isEmpty);
      listEl.innerHTML = tasks
        .slice(0, 6)
        .map(
          (t) => `
        <li class="px-5 py-3 flex items-center justify-between gap-3">
          <div class="min-w-0">
            <p class="font-body text-sm text-ink truncate">${escapeHtml(t.project?.name ?? "Proyek")}</p>
            <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">${escapeHtml(t.project?.location ?? "-")}</p>
          </div>
          <span class="font-mono text-[9px] uppercase tracking-widest border border-ink px-2 py-1 shrink-0">${STATUS_LABEL[t.status]}</span>
        </li>
      `
        )
        .join("");
    } catch (err) {
      console.error("[loadTasks] gagal fetch backend:", err);
    }
  }

  interface DailyReportRow {
    id: string;
    reportDate: string;
    description: string;
    project?: { name: string };
  }

  async function loadActivity(): Promise<void> {
    const emptyEl = document.getElementById("dashboard-activity-empty");
    const listEl = document.getElementById("dashboard-activity-list") as HTMLUListElement | null;
    if (!listEl) return;
    try {
      const res = await adminApiFetch(`${apiUrl}/api/technical/daily-report`);
      const json = await res.json();
      if (!res.ok) return;
      const reports: DailyReportRow[] = json.data ?? [];
      const isEmpty = reports.length === 0;
      emptyEl?.classList.toggle("hidden", !isEmpty);
      listEl.classList.toggle("hidden", isEmpty);
      listEl.innerHTML = reports
        .slice(0, 6)
        .map(
          (r) => `
        <li class="px-5 py-3">
          <p class="font-body text-sm text-ink truncate">Laporan harian — ${escapeHtml(r.project?.name ?? "-")}</p>
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-0.5">${escapeHtml(r.reportDate)}</p>
        </li>
      `
        )
        .join("");
    } catch (err) {
      console.error("[loadActivity] gagal fetch backend:", err);
    }
  }

  loadSummary();
  loadTasks();
  loadActivity();
</script>
