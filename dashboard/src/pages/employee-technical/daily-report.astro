---
import EmployeeLayout from "../../layouts/EmployeeLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<EmployeeLayout title="Daily Report" activeNav="daily-report">
  <PageHeader heading="Daily Report" sub="Isi laporan pekerjaan harian Anda" crumbs={[{ label: "Kerja Lapangan" }, { label: "Daily Report" }]} />

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 sm:gap-6 mb-8">
    <!-- Form -->
    <form id="daily-report-form" class="panel lg:col-span-3">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Laporan Baru</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Isi sesuai pekerjaan hari ini</p>
      </div>
      <div class="p-5 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="field-label" for="report-date">Tanggal</label>
            <input id="report-date" type="date" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="report-task">Tugas Terkait</label>
            <select id="report-task" class="field-input">
              <option value="">Pilih tugas…</option>
            </select>
          </div>
        </div>

        <div>
          <label class="field-label" for="report-description">Deskripsi Pekerjaan</label>
          <textarea id="report-description" rows="4" class="field-input resize-none" placeholder="Jelaskan pekerjaan yang dilakukan hari ini…"></textarea>
        </div>

        <div>
          <label class="field-label" for="report-materials">Material / Alat Digunakan</label>
          <input id="report-materials" type="text" class="field-input" placeholder="Contoh: kabel NYA 2.5mm, detector asap" />
        </div>

        <div>
          <label class="field-label" for="report-obstacle">Kendala / Catatan</label>
          <textarea id="report-obstacle" rows="3" class="field-input resize-none" placeholder="Kendala di lapangan (opsional)…"></textarea>
        </div>

        <div>
          <label class="field-label" for="report-photo">Upload Foto Pekerjaan</label>
          <label for="report-photo" class="flex flex-col items-center justify-center gap-2 border-2 border-dashed border-hairline hover:border-ink transition-colors py-8 cursor-pointer text-center">
            <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-smoke" stroke="currentColor" stroke-width="1.5">
              <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
              <circle cx="12" cy="13" r="4"/>
            </svg>
            <span class="font-mono text-[10px] text-smoke uppercase tracking-widest">Klik untuk pilih foto</span>
            <input id="report-photo" type="file" accept="image/*" capture="environment" class="hidden" />
          </label>
          <p id="report-photo-filename" class="font-mono text-[10px] text-smoke mt-1.5"></p>
        </div>
      </div>
      <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-hairline">
        <button type="reset" class="btn-secondary text-xs">Reset</button>
        <button type="submit" class="btn-primary text-xs">Kirim Laporan</button>
      </div>
    </form>

    <!-- Tips / guide panel -->
    <div class="panel lg:col-span-2 h-fit">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Panduan Singkat</h3>
      </div>
      <ul class="p-5 space-y-4">
        <li class="flex gap-3">
          <span class="font-mono text-xs text-signal shrink-0">01</span>
          <p class="text-sm text-charcoal">Isi laporan sebelum jam kerja berakhir agar tidak terlewat.</p>
        </li>
        <li class="flex gap-3">
          <span class="font-mono text-xs text-signal shrink-0">02</span>
          <p class="text-sm text-charcoal">Sertakan foto sebelum dan sesudah pekerjaan sebagai bukti.</p>
        </li>
        <li class="flex gap-3">
          <span class="font-mono text-xs text-signal shrink-0">03</span>
          <p class="text-sm text-charcoal">Catat kendala di lapangan agar bisa ditindaklanjuti tim terkait.</p>
        </li>
      </ul>
    </div>
  </div>

  <!-- History -->
  <div class="panel overflow-hidden">
    <div class="px-5 py-4 border-b-2 border-ink">
      <h3 class="font-display text-lg text-ink leading-none">Riwayat Laporan</h3>
      <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Laporan yang sudah dikirim</p>
    </div>
    <div class="overflow-x-auto">
      <table id="report-table" class="data-table">
        <thead>
          <tr>
            <th>Tanggal</th>
            <th class="hidden sm:table-cell">Tugas Terkait</th>
            <th class="hidden md:table-cell">Deskripsi</th>
            <th>Foto</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="report-body"></tbody>
      </table>
    </div>
    <div id="report-empty" class="empty-state min-h-52">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
      </svg>
      <p>Belum ada laporan yang dikirim</p>
    </div>
  </div>
</EmployeeLayout>

<script>
  import { adminApiFetch } from "../../lib/auth";
  import { escapeHtml } from "../../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  const dateInput = document.getElementById("report-date") as HTMLInputElement | null;
  if (dateInput) {
    dateInput.value = new Date().toISOString().split("T")[0];
  }

  interface Assignment {
    id: string;
    status: string;
    project?: { id: number; name: string; code: string };
  }
  let taskOptions: Assignment[] = [];

  async function loadTaskOptions(): Promise<void> {
    const select = document.getElementById("report-task") as HTMLSelectElement;
    try {
      const res = await adminApiFetch(`${apiUrl}/api/technical/tasks`);
      const json = await res.json();
      if (!res.ok) return;
      taskOptions = json.data ?? [];
      select.innerHTML =
        `<option value="">Pilih tugas…</option>` +
        taskOptions
          .map((t) => `<option value="${t.id}">${escapeHtml(t.project?.name ?? "Proyek")} — ${escapeHtml(t.project?.code ?? "")}</option>`)
          .join("");
    } catch (err) {
      console.error("[loadTaskOptions] gagal fetch backend:", err);
    }
  }

  document.getElementById("report-photo")?.addEventListener("change", (e) => {
    const input = e.target as HTMLInputElement;
    const label = document.getElementById("report-photo-filename");
    if (label) {
      label.textContent = input.files && input.files[0] ? input.files[0].name : "";
    }
  });

  interface DailyReportRow {
    id: string;
    reportDate: string;
    description: string;
    status: string;
    project?: { name: string };
  }

  async function loadHistory(): Promise<void> {
    const tableBody = document.getElementById("report-body") as HTMLTableSectionElement;
    const table = document.getElementById("report-table") as HTMLTableElement;
    const emptyState = document.getElementById("report-empty") as HTMLDivElement;
    try {
      const res = await adminApiFetch(`${apiUrl}/api/technical/daily-report`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat riwayat laporan", "error");
        return;
      }
      const reports: DailyReportRow[] = json.data ?? [];
      const isEmpty = reports.length === 0;
      table.classList.toggle("hidden", isEmpty);
      emptyState.classList.toggle("hidden", !isEmpty);
      tableBody.innerHTML = reports
        .map(
          (r) => `
        <tr>
          <td class="font-mono text-xs text-charcoal">${escapeHtml(r.reportDate)}</td>
          <td class="hidden sm:table-cell font-mono text-xs text-charcoal">${escapeHtml(r.project?.name ?? "-")}</td>
          <td class="hidden md:table-cell font-mono text-xs text-charcoal truncate max-w-xs">${escapeHtml(r.description)}</td>
          <td class="font-mono text-xs text-smoke">-</td>
          <td><span class="font-mono text-[9px] uppercase tracking-widest border px-2 py-1 ${r.status === "reviewed" ? "bg-hairline/20 text-smoke border-hairline" : "bg-signal/10 text-signal border-signal"}">${r.status === "reviewed" ? "Ditinjau" : "Terkirim"}</span></td>
        </tr>
      `
        )
        .join("");
    } catch (err) {
      console.error("[loadHistory] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  document.getElementById("daily-report-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const taskId = (document.getElementById("report-task") as HTMLSelectElement).value;
    const description = (document.getElementById("report-description") as HTMLTextAreaElement).value.trim();
    const materialsUsed = (document.getElementById("report-materials") as HTMLInputElement).value.trim();
    const obstacle = (document.getElementById("report-obstacle") as HTMLTextAreaElement).value.trim();
    const photoInput = document.getElementById("report-photo") as HTMLInputElement;

    if (!description) {
      window.showToast?.("Deskripsi pekerjaan wajib diisi", "error");
      return;
    }

    const selectedTask = taskOptions.find((t) => t.id === taskId);

    const formData = new FormData();
    if (selectedTask?.project?.id) formData.append("projectId", String(selectedTask.project.id));
    if (taskId) formData.append("assignmentId", taskId);
    formData.append("reportDate", dateInput?.value || new Date().toISOString().split("T")[0]);
    formData.append("description", description);
    if (materialsUsed) formData.append("materialsUsed", materialsUsed);
    if (obstacle) formData.append("obstacle", obstacle);
    if (photoInput.files?.[0]) formData.append("photo", photoInput.files[0]);

    try {
      const res = await adminApiFetch(`${apiUrl}/api/technical/daily-report`, {
        method: "POST",
        body: formData,
      });
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal mengirim laporan", "error");
        return;
      }
      window.showToast?.(json.message ?? "Laporan harian terkirim");
      (document.getElementById("daily-report-form") as HTMLFormElement).reset();
      if (dateInput) dateInput.value = new Date().toISOString().split("T")[0];
      const label = document.getElementById("report-photo-filename");
      if (label) label.textContent = "";
      await loadHistory();
    } catch (err) {
      console.error("[daily-report-form submit] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  });

  loadTaskOptions();
  loadHistory();
</script>
