---
import EmployeeLayout from "../../layouts/EmployeeLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<EmployeeLayout title="Daily Report" activeNav="daily-report">
  <PageHeader heading="Daily Report" sub="Isi laporan pekerjaan harian Anda" crumbs={[{ label: "Kerja Lapangan" }, { label: "Daily Report" }]} />

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 sm:gap-6 mb-8">
    <!-- Form -->
    <form id="daily-report-form" class="panel lg:col-span-3">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Laporan Baru</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Isi sesuai pekerjaan hari ini</p>
      </div>
      <div class="p-5 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="field-label" for="report-date">Tanggal</label>
            <input id="report-date" type="date" class="field-input" />
          </div>
          <div>
            <label class="field-label" for="report-task">Tugas Terkait</label>
            <select id="report-task" class="field-input">
              <option value="">Pilih tugas…</option>
            </select>
          </div>
        </div>

        <div>
          <label class="field-label" for="report-description">Deskripsi Pekerjaan</label>
          <textarea id="report-description" rows="4" class="field-input resize-none" placeholder="Jelaskan pekerjaan yang dilakukan hari ini…"></textarea>
        </div>

        <div>
          <label class="field-label" for="report-materials">Material / Alat Digunakan</label>
          <input id="report-materials" type="text" class="field-input" placeholder="Contoh: kabel NYA 2.5mm, detector asap" />
        </div>

        <div>
          <label class="field-label" for="report-obstacle">Kendala / Catatan</label>
          <textarea id="report-obstacle" rows="3" class="field-input resize-none" placeholder="Kendala di lapangan (opsional)…"></textarea>
        </div>

        <div>
          <label class="field-label" for="report-photo">Upload Foto Pekerjaan</label>
          <label for="report-photo" class="flex flex-col items-center justify-center gap-2 border-2 border-dashed border-hairline hover:border-ink transition-colors py-8 cursor-pointer text-center">
            <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-smoke" stroke="currentColor" stroke-width="1.5">
              <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
              <circle cx="12" cy="13" r="4"/>
            </svg>
            <span class="font-mono text-[10px] text-smoke uppercase tracking-widest">Klik untuk pilih foto</span>
            <input id="report-photo" type="file" accept="image/*" capture="environment" multiple class="hidden" />
          </label>
          <p id="report-photo-filename" class="font-mono text-[10px] text-smoke mt-1.5"></p>
        </div>
      </div>
      <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-hairline">
        <button type="reset" class="btn-secondary text-xs">Reset</button>
        <button type="submit" class="btn-primary text-xs">Kirim Laporan</button>
      </div>
    </form>

    <!-- Tips / guide panel -->
    <div class="panel lg:col-span-2 h-fit">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Panduan Singkat</h3>
      </div>
      <ul class="p-5 space-y-4">
        <li class="flex gap-3">
          <span class="font-mono text-xs text-signal shrink-0">01</span>
          <p class="text-sm text-charcoal">Isi laporan sebelum jam kerja berakhir agar tidak terlewat.</p>
        </li>
        <li class="flex gap-3">
          <span class="font-mono text-xs text-signal shrink-0">02</span>
          <p class="text-sm text-charcoal">Sertakan foto sebelum dan sesudah pekerjaan sebagai bukti.</p>
        </li>
        <li class="flex gap-3">
          <span class="font-mono text-xs text-signal shrink-0">03</span>
          <p class="text-sm text-charcoal">Catat kendala di lapangan agar bisa ditindaklanjuti tim terkait.</p>
        </li>
      </ul>
    </div>
  </div>

  <!-- History -->
  <div class="panel overflow-hidden">
    <div class="px-5 py-4 border-b-2 border-ink">
      <h3 class="font-display text-lg text-ink leading-none">Riwayat Laporan</h3>
      <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Laporan yang sudah dikirim</p>
    </div>
    <div class="overflow-x-auto">
      <table id="report-table" class="data-table">
        <thead>
          <tr>
            <th>Tanggal</th>
            <th class="hidden sm:table-cell">Tugas Terkait</th>
            <th class="hidden md:table-cell">Deskripsi</th>
            <th>Foto</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="report-body"></tbody>
      </table>
    </div>
    <div id="report-empty" class="empty-state min-h-52">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
      </svg>
      <p>Belum ada laporan yang dikirim</p>
    </div>
  </div>
</EmployeeLayout>

<script>
  // Prototype UI only — belum terhubung ke endpoint daily report.
  const dateInput = document.getElementById("report-date") as HTMLInputElement | null;
  if (dateInput) {
    dateInput.value = new Date().toISOString().split("T")[0];
  }

  document.getElementById("report-photo")?.addEventListener("change", (e) => {
    const input = e.target as HTMLInputElement;
    const label = document.getElementById("report-photo-filename");
    if (label) {
      label.textContent = input.files && input.files.length > 0
        ? `${input.files.length} foto dipilih`
        : "";
    }
  });

  document.getElementById("daily-report-form")?.addEventListener("submit", (e) => {
    e.preventDefault();
    window.showToast?.("Laporan harian terkirim (prototype)", "success");
    (e.target as HTMLFormElement).reset();
    if (dateInput) dateInput.value = new Date().toISOString().split("T")[0];
    const label = document.getElementById("report-photo-filename");
    if (label) label.textContent = "";
  });
</script>
