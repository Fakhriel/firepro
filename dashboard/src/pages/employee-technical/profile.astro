---
import EmployeeLayout from "../../layouts/EmployeeLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<EmployeeLayout title="Profile" activeNav="profile">
  <PageHeader heading="Profile" sub="Informasi akun & data diri Anda" crumbs={[{ label: "Kerja Lapangan" }, { label: "Profile" }]} />

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 sm:gap-6">
    <!-- Profile card -->
    <div class="panel lg:col-span-2 h-fit">
      <div class="flex flex-col items-center text-center px-6 py-8 border-b-2 border-ink">
        <div class="w-20 h-20 rounded-full bg-ink text-paper flex items-center justify-center font-display text-3xl mb-4">
          <span id="profile-avatar">K</span>
        </div>
        <p id="profile-name" class="font-display text-xl text-ink leading-none">Karyawan</p>
        <p class="font-mono text-[10px] text-smoke uppercase tracking-widest mt-2">Teknisi Lapangan</p>
        <span id="profile-status" class="badge badge-active mt-3">Aktif</span>
      </div>
      <dl class="p-5 space-y-4">
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-[10px] uppercase tracking-widest text-smoke">ID Karyawan</dt>
          <dd id="profile-employee-id" class="text-sm text-ink font-semibold">—</dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-[10px] uppercase tracking-widest text-smoke">Email</dt>
          <dd id="profile-email" class="text-sm text-ink font-semibold truncate">—</dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-[10px] uppercase tracking-widest text-smoke">No. Telepon</dt>
          <dd id="profile-phone" class="text-sm text-ink font-semibold">—</dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-[10px] uppercase tracking-widest text-smoke">Bergabung Sejak</dt>
          <dd id="profile-joined" class="text-sm text-ink font-semibold">—</dd>
        </div>
      </dl>
    </div>

    <!-- Edit + password -->
    <div class="lg:col-span-3 space-y-4 sm:space-y-6">
      <form id="profile-edit-form" class="panel">
        <div class="px-5 py-4 border-b-2 border-ink">
          <h3 class="font-display text-lg text-ink leading-none">Data Diri</h3>
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Perbarui informasi kontak Anda</p>
        </div>
        <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="field-label" for="edit-name">Nama Lengkap</label>
            <input id="edit-name" type="text" class="field-input" placeholder="Nama lengkap" />
          </div>
          <div>
            <label class="field-label" for="edit-phone">No. Telepon</label>
            <input id="edit-phone" type="tel" class="field-input" placeholder="08xx-xxxx-xxxx" />
          </div>
          <div class="sm:col-span-2">
            <label class="field-label" for="edit-email">Email</label>
            <input id="edit-email" type="email" class="field-input" placeholder="nama@firepro.id" />
          </div>
        </div>
        <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-hairline">
          <button type="reset" class="btn-secondary text-xs">Batal</button>
          <button type="submit" class="btn-primary text-xs">Simpan Perubahan</button>
        </div>
      </form>

      <form id="profile-password-form" class="panel">
        <div class="px-5 py-4 border-b-2 border-ink">
          <h3 class="font-display text-lg text-ink leading-none">Ubah Password</h3>
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Jaga keamanan akun Anda</p>
        </div>
        <div class="p-5 grid grid-cols-1 gap-4">
          <div>
            <label class="field-label" for="password-current">Password Lama</label>
            <input id="password-current" type="password" class="field-input" placeholder="••••••••" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="field-label" for="password-new">Password Baru</label>
              <input id="password-new" type="password" class="field-input" placeholder="••••••••" />
            </div>
            <div>
              <label class="field-label" for="password-confirm">Konfirmasi Password</label>
              <input id="password-confirm" type="password" class="field-input" placeholder="••••••••" />
            </div>
          </div>
        </div>
        <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-hairline">
          <button type="submit" class="btn-primary text-xs">Update Password</button>
        </div>
      </form>
    </div>
  </div>
</EmployeeLayout>

<script>
  import { adminApiFetch, getAdminAuth, setAdminAuth } from "../../lib/auth";
  import { escapeHtml } from "../../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface ProfileData {
    id: number;
    name: string;
    username: string;
    email?: string;
    phone?: string;
    createdAt?: string;
  }

  function formatJoined(iso?: string): string {
    if (!iso) return "-";
    try {
      return new Date(iso).toLocaleDateString("id-ID", { day: "2-digit", month: "long", year: "numeric" });
    } catch {
      return "-";
    }
  }

  async function loadProfile(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/technical/profile`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat profil", "error");
        return;
      }
      const p: ProfileData = json.data?.admin ?? json.data;

      (document.getElementById("profile-avatar") as HTMLElement).textContent = (p.name || "K").charAt(0).toUpperCase();
      (document.getElementById("profile-name") as HTMLElement).textContent = p.name || "-";
      (document.getElementById("profile-employee-id") as HTMLElement).textContent = p.username || String(p.id);
      (document.getElementById("profile-email") as HTMLElement).textContent = p.email || "-";
      (document.getElementById("profile-phone") as HTMLElement).textContent = p.phone || "-";
      (document.getElementById("profile-joined") as HTMLElement).textContent = formatJoined(p.createdAt);

      (document.getElementById("edit-name") as HTMLInputElement).value = p.name || "";
      (document.getElementById("edit-phone") as HTMLInputElement).value = p.phone || "";
      (document.getElementById("edit-email") as HTMLInputElement).value = p.email || "";
    } catch (err) {
      console.error("[loadProfile] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  document.getElementById("profile-edit-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const name = (document.getElementById("edit-name") as HTMLInputElement).value.trim();
    const phone = (document.getElementById("edit-phone") as HTMLInputElement).value.trim();
    const email = (document.getElementById("edit-email") as HTMLInputElement).value.trim();

    if (!name) {
      window.showToast?.("Nama tidak boleh kosong", "error");
      return;
    }

    try {
      const res = await adminApiFetch(`${apiUrl}/api/technical/profile`, {
        method: "PATCH",
        body: JSON.stringify({ name, phone: phone || null, email: email || null }),
      });
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal menyimpan data diri", "error");
        return;
      }
      window.showToast?.("Data diri tersimpan");

      const { token, admin } = getAdminAuth();
      if (token && admin) setAdminAuth(token, { ...admin, name, phone, email });

      await loadProfile();
    } catch (err) {
      console.error("[profile-edit-form submit] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  });

  document.getElementById("profile-password-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const currentPassword = (document.getElementById("password-current") as HTMLInputElement).value;
    const newPass = (document.getElementById("password-new") as HTMLInputElement).value;
    const confirmPass = (document.getElementById("password-confirm") as HTMLInputElement).value;

    if (!currentPassword) {
      window.showToast?.("Password lama wajib diisi", "error");
      return;
    }
    if (newPass.length < 6) {
      window.showToast?.("Password baru minimal 6 karakter", "error");
      return;
    }
    if (newPass !== confirmPass) {
      window.showToast?.("Konfirmasi password tidak cocok", "error");
      return;
    }

    try {
      const res = await adminApiFetch(`${apiUrl}/api/technical/profile/password`, {
        method: "PATCH",
        body: JSON.stringify({ currentPassword, newPassword: newPass }),
      });
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memperbarui password", "error");
        return;
      }
      window.showToast?.(json.message ?? "Password berhasil diperbarui");
      (e.target as HTMLFormElement).reset();
    } catch (err) {
      console.error("[profile-password-form submit] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  });

  loadProfile();
</script>
