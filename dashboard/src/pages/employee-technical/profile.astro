---
import EmployeeLayout from "../../layouts/EmployeeLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<EmployeeLayout title="Profile" activeNav="profile">
  <PageHeader heading="Profile" sub="Informasi akun & data diri Anda" crumbs={[{ label: "Kerja Lapangan" }, { label: "Profile" }]} />

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 sm:gap-6">
    <!-- Profile card -->
    <div class="panel lg:col-span-2 h-fit">
      <div class="flex flex-col items-center text-center px-6 py-8 border-b-2 border-ink">
        <div class="w-20 h-20 rounded-full bg-ink text-paper flex items-center justify-center font-display text-3xl mb-4">
          <span id="profile-avatar">K</span>
        </div>
        <p id="profile-name" class="font-display text-xl text-ink leading-none">Karyawan</p>
        <p class="font-mono text-[10px] text-smoke uppercase tracking-widest mt-2">Teknisi Lapangan</p>
        <span id="profile-status" class="badge badge-active mt-3">Aktif</span>
      </div>
      <dl class="p-5 space-y-4">
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-[10px] uppercase tracking-widest text-smoke">ID Karyawan</dt>
          <dd id="profile-employee-id" class="text-sm text-ink font-semibold">—</dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-[10px] uppercase tracking-widest text-smoke">Email</dt>
          <dd id="profile-email" class="text-sm text-ink font-semibold truncate">—</dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-[10px] uppercase tracking-widest text-smoke">No. Telepon</dt>
          <dd id="profile-phone" class="text-sm text-ink font-semibold">—</dd>
        </div>
        <div class="flex items-center justify-between gap-3">
          <dt class="font-mono text-[10px] uppercase tracking-widest text-smoke">Bergabung Sejak</dt>
          <dd id="profile-joined" class="text-sm text-ink font-semibold">—</dd>
        </div>
      </dl>
    </div>

    <!-- Edit + password -->
    <div class="lg:col-span-3 space-y-4 sm:space-y-6">
      <form id="profile-edit-form" class="panel">
        <div class="px-5 py-4 border-b-2 border-ink">
          <h3 class="font-display text-lg text-ink leading-none">Data Diri</h3>
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Perbarui informasi kontak Anda</p>
        </div>
        <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="field-label" for="edit-name">Nama Lengkap</label>
            <input id="edit-name" type="text" class="field-input" placeholder="Nama lengkap" />
          </div>
          <div>
            <label class="field-label" for="edit-phone">No. Telepon</label>
            <input id="edit-phone" type="tel" class="field-input" placeholder="08xx-xxxx-xxxx" />
          </div>
          <div class="sm:col-span-2">
            <label class="field-label" for="edit-email">Email</label>
            <input id="edit-email" type="email" class="field-input" placeholder="nama@firepro.id" />
          </div>
        </div>
        <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-hairline">
          <button type="reset" class="btn-secondary text-xs">Batal</button>
          <button type="submit" class="btn-primary text-xs">Simpan Perubahan</button>
        </div>
      </form>

      <form id="profile-password-form" class="panel">
        <div class="px-5 py-4 border-b-2 border-ink">
          <h3 class="font-display text-lg text-ink leading-none">Ubah Password</h3>
          <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">Jaga keamanan akun Anda</p>
        </div>
        <div class="p-5 grid grid-cols-1 gap-4">
          <div>
            <label class="field-label" for="password-current">Password Lama</label>
            <input id="password-current" type="password" class="field-input" placeholder="••••••••" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="field-label" for="password-new">Password Baru</label>
              <input id="password-new" type="password" class="field-input" placeholder="••••••••" />
            </div>
            <div>
              <label class="field-label" for="password-confirm">Konfirmasi Password</label>
              <input id="password-confirm" type="password" class="field-input" placeholder="••••••••" />
            </div>
          </div>
        </div>
        <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-hairline">
          <button type="submit" class="btn-primary text-xs">Update Password</button>
        </div>
      </form>
    </div>
  </div>
</EmployeeLayout>

<script>
  // Prototype UI only — belum terhubung ke endpoint profile employee.
  document.getElementById("profile-edit-form")?.addEventListener("submit", (e) => {
    e.preventDefault();
    window.showToast?.("Data diri tersimpan (prototype)", "success");
  });

  document.getElementById("profile-password-form")?.addEventListener("submit", (e) => {
    e.preventDefault();
    const newPass = (document.getElementById("password-new") as HTMLInputElement | null)?.value ?? "";
    const confirmPass = (document.getElementById("password-confirm") as HTMLInputElement | null)?.value ?? "";

    if (newPass && newPass !== confirmPass) {
      window.showToast?.("Konfirmasi password tidak cocok", "error");
      return;
    }

    window.showToast?.("Password berhasil diperbarui (prototype)", "success");
    (e.target as HTMLFormElement).reset();
  });
</script>
