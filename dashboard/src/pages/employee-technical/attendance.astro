---
import EmployeeLayout from "../../layouts/EmployeeLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<EmployeeLayout title="Attendance" activeNav="attendance">
  <PageHeader heading="Attendance" sub="Check in dan check out kehadiran Anda" crumbs={[{ label: "Kerja Lapangan" }, { label: "Attendance" }]} />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6 mb-8">
    <!-- Check in/out card -->
    <div class="panel lg:col-span-1 flex flex-col items-center text-center px-6 py-8">
      <p class="font-mono text-[10px] uppercase tracking-widest text-smoke mb-2">Waktu Saat Ini</p>
      <p id="live-clock" class="font-display text-4xl text-ink leading-none mb-1">--:--:--</p>
      <p id="live-date" class="font-mono text-xs text-smoke mb-6">—</p>

      <div id="attendance-status-badge" class="badge badge-inactive mb-6">Belum Check In</div>

      <div class="flex items-center gap-1.5 font-mono text-[10px] text-smoke uppercase tracking-widest mb-6">
        <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="1.75">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <span id="attendance-location">Lokasi akan terdeteksi otomatis</span>
      </div>

      <button id="btn-check-in" type="button" class="btn-primary w-full justify-center">
        Check In
      </button>
      <button id="btn-check-out" type="button" class="btn-danger w-full justify-center hidden">
        Check Out
      </button>
    </div>

    <!-- Today summary -->
    <div class="panel lg:col-span-2">
      <div class="px-5 py-4 border-b-2 border-ink">
        <h3 class="font-display text-lg text-ink leading-none">Ringkasan Hari Ini</h3>
        <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">
          {new Date().toLocaleDateString("id-ID", { weekday: "long", day: "numeric", month: "long", year: "numeric" })}
        </p>
      </div>
      <div class="grid grid-cols-3 divide-x divide-hairline">
        <div class="px-5 py-6 text-center">
          <p class="font-mono text-[9px] uppercase tracking-widest text-smoke mb-2">Jam Masuk</p>
          <p id="summary-check-in" class="font-display text-2xl text-ink">--:--</p>
        </div>
        <div class="px-5 py-6 text-center">
          <p class="font-mono text-[9px] uppercase tracking-widest text-smoke mb-2">Jam Keluar</p>
          <p id="summary-check-out" class="font-display text-2xl text-ink">--:--</p>
        </div>
        <div class="px-5 py-6 text-center">
          <p class="font-mono text-[9px] uppercase tracking-widest text-smoke mb-2">Durasi Kerja</p>
          <p id="summary-duration" class="font-display text-2xl text-ink">--</p>
        </div>
      </div>
    </div>
  </div>

  <!-- History -->
  <div class="panel overflow-hidden">
    <div class="px-5 py-4 border-b-2 border-ink">
      <h3 class="font-display text-lg text-ink leading-none">Riwayat Kehadiran</h3>
      <p class="font-mono text-[9px] text-smoke uppercase tracking-widest mt-1">30 hari terakhir</p>
    </div>
    <div class="overflow-x-auto">
      <table id="attendance-table" class="data-table">
        <thead>
          <tr>
            <th>Tanggal</th>
            <th>Jam Masuk</th>
            <th>Jam Keluar</th>
            <th class="hidden sm:table-cell">Durasi</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="attendance-body"></tbody>
      </table>
    </div>
    <div id="attendance-empty" class="empty-state min-h-52">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 16 14"/>
      </svg>
      <p>Belum ada riwayat kehadiran</p>
    </div>
  </div>
</EmployeeLayout>

<script>
  // Live clock
  function tickClock(): void {
    const now = new Date();
    const clockEl = document.getElementById("live-clock");
    const dateEl = document.getElementById("live-date");
    if (clockEl) {
      clockEl.textContent = now.toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
    }
    if (dateEl) {
      dateEl.textContent = now.toLocaleDateString("id-ID", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
    }
  }
  tickClock();
  setInterval(tickClock, 1000);

  // Check in / out toggle — prototype only, belum terhubung backend absensi.
  const btnIn = document.getElementById("btn-check-in");
  const btnOut = document.getElementById("btn-check-out");
  const badge = document.getElementById("attendance-status-badge");
  const summaryIn = document.getElementById("summary-check-in");
  const summaryOut = document.getElementById("summary-check-out");
  const summaryDuration = document.getElementById("summary-duration");

  let checkInTime: Date | null = null;

  btnIn?.addEventListener("click", () => {
    checkInTime = new Date();
    const timeStr = checkInTime.toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
    if (summaryIn) summaryIn.textContent = timeStr;
    if (badge) {
      badge.textContent = "Sedang Bekerja";
      badge.className = "badge badge-active mb-6";
    }
    btnIn?.classList.add("hidden");
    btnOut?.classList.remove("hidden");
    window.showToast?.(`Check in berhasil pukul ${timeStr} (prototype)`, "success");
  });

  btnOut?.addEventListener("click", () => {
    const now = new Date();
    const timeStr = now.toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
    if (summaryOut) summaryOut.textContent = timeStr;
    if (checkInTime) {
      const diffMs = now.getTime() - checkInTime.getTime();
      const hours = Math.floor(diffMs / 3600000);
      const minutes = Math.floor((diffMs % 3600000) / 60000);
      if (summaryDuration) summaryDuration.textContent = `${hours}j ${minutes}m`;
    }
    if (badge) {
      badge.textContent = "Selesai Check Out";
      badge.className = "badge badge-inactive mb-6";
    }
    btnOut?.classList.add("hidden");
    btnIn?.classList.remove("hidden");
    window.showToast?.(`Check out berhasil pukul ${timeStr} (prototype)`, "success");
  });
</script>
