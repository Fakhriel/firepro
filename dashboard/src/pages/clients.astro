---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<DashboardLayout title="Clients" activeNav="clients">
  <PageHeader heading="Clients" sub="Data klien terdaftar" crumbs={[{ label: "Pengguna" }, { label: "Clients" }]}>
    <button id="btn-export-clients" type="button" class="btn-secondary text-xs gap-1.5">
      <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="1.75">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/>
        <line x1="9" y1="15" x2="15" y2="15"/>
      </svg>
      Export PDF
    </button>
  </PageHeader>

  <!-- Filter -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <input type="search" placeholder="Cari nama / email…" class="field-input sm:max-w-xs" />
    <select class="field-input sm:w-40">
      <option value="">Semua Status</option>
      <option value="active">Aktif</option>
      <option value="inactive">Nonaktif</option>
    </select>
  </div>

  <!-- Table -->
  <div class="panel overflow-hidden">
    <div class="overflow-x-auto">
      <table id="clients-table" class="data-table">
        <thead>
          <tr>
            <th class="w-10">#</th>
            <th>Nama</th>
            <th class="hidden sm:table-cell">Email</th>
            <th class="hidden md:table-cell">Telepon</th>
            <th class="hidden lg:table-cell">Terdaftar</th>
            <th class="hidden md:table-cell">Total Proyek</th>
            <th>Status</th>
            <th class="text-right">Aksi</th>
          </tr>
        </thead>
        <tbody id="clients-body"></tbody>
      </table>
    </div>
    <div id="clients-empty" class="empty-state min-h-56">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <p>Belum ada klien terdaftar</p>
    </div>
    <div class="flex items-center justify-between px-4 py-3 border-t border-hairline">
      <span class="font-mono text-[10px] text-smoke">0 klien</span>
      <div class="flex items-center gap-1">
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>←</button>
        <span class="font-mono text-xs px-3 py-1.5 border border-hairline">1</span>
        <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" disabled>→</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { exportTableToPDF } from "../lib/export";
  import { adminApiFetch } from "../lib/auth";
  import { escapeHtml } from "../lib/escapeHtml";

  const apiUrl =
    document.getElementById("dashboard-root")?.dataset.apiUrl || "http://localhost:4000";

  interface AdminClient {
    id: number;
    name: string;
    email: string | null;
    phone: string | null;
    status: "active" | "inactive";
    createdAt: string;
    totalProjects: number;
  }

  let allClients: AdminClient[] = [];

  const tableBody = document.getElementById("clients-body") as HTMLTableSectionElement;
  const emptyState = document.getElementById("clients-empty") as HTMLDivElement;
  const table = document.getElementById("clients-table") as HTMLTableElement;
  const countLabel = document.querySelector<HTMLSpanElement>(
    ".font-mono.text-\\[10px\\].text-smoke"
  );

  function formatDate(value: string): string {
    return new Intl.DateTimeFormat("id-ID", { day: "2-digit", month: "short", year: "numeric" }).format(
      new Date(value)
    );
  }

  function renderTable(clients: AdminClient[]): void {
    tableBody.innerHTML = "";

    const isEmpty = clients.length === 0;
    table.classList.toggle("hidden", isEmpty);
    emptyState.classList.toggle("hidden", !isEmpty);
    if (countLabel) countLabel.textContent = `${clients.length} klien`;

    clients.forEach((c, index) => {
      const isActive = c.status === "active";
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="font-mono text-xs text-smoke">${index + 1}</td>
        <td class="font-semibold text-ink">${escapeHtml(c.name)}</td>
        <td class="hidden sm:table-cell font-mono text-xs text-smoke">${escapeHtml(c.email ?? "-")}</td>
        <td class="hidden md:table-cell font-mono text-xs text-smoke">${escapeHtml(c.phone ?? "-")}</td>
        <td class="hidden lg:table-cell font-mono text-xs text-smoke">${formatDate(c.createdAt)}</td>
        <td class="hidden md:table-cell font-mono text-xs">${Number(c.totalProjects)}</td>
        <td>
          <span class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wide border ${isActive ? "border-ink text-ink" : "border-smoke text-smoke"}">
            ${isActive ? "Aktif" : "Nonaktif"}
          </span>
        </td>
        <td class="text-right whitespace-nowrap">
          <span class="font-mono text-[10px] text-smoke">—</span>
        </td>
      `;
      tableBody.appendChild(tr);
    });
  }

  function applyFilters(): void {
    const keyword = (document.querySelector('input[type="search"]') as HTMLInputElement)?.value
      .trim()
      .toLowerCase();
    const status = (document.querySelector('select') as HTMLSelectElement)?.value;

    const filtered = allClients.filter((c) => {
      if (keyword && !c.name.toLowerCase().includes(keyword) && !(c.email ?? "").toLowerCase().includes(keyword))
        return false;
      if (status && c.status !== status) return false;
      return true;
    });

    renderTable(filtered);
  }

  async function loadClients(): Promise<void> {
    try {
      const res = await adminApiFetch(`${apiUrl}/api/clients?limit=100`);
      const json = await res.json();
      if (!res.ok) {
        window.showToast?.(json.error ?? "Gagal memuat data klien", "error");
        return;
      }
      allClients = json.data ?? [];
      applyFilters();
    } catch (err) {
      console.error("[loadClients] gagal fetch backend:", err);
      window.showToast?.("Tidak bisa terhubung ke server", "error");
    }
  }

  document.querySelector('input[type="search"]')?.addEventListener("input", applyFilters);
  document.querySelector("select")?.addEventListener("change", applyFilters);

  document.getElementById("btn-export-clients")?.addEventListener("click", () => {
    exportTableToPDF("clients-table", { title: "Data Klien", subtitle: "Klien terdaftar FIREPRO" });
  });

  loadClients();
</script>