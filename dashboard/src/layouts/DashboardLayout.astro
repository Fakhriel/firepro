---
import Base from "./Base.astro";
import Sidebar from "../components/Sidebar.astro";
import Topbar from "../components/Topbar.astro";

export interface Props {
  title?: string;
  activeNav?: string;
}

const { title = "FIREPRO Dashboard", activeNav = "" } = Astro.props;

const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:4000";
---

<Base title={`${title} — FIREPRO Admin`}>
  <div id="dashboard-root" data-api-url={API_URL} class="hidden min-h-screen flex bg-paper">

    <!-- ─── Sidebar (desktop) ─────────────────────────────── -->
    <Sidebar activeNav={activeNav} />

    <!-- ─── Main area ─────────────────────────────────────── -->
    <div class="flex-1 flex flex-col min-w-0 lg:ml-60">

      <!-- Mobile overlay (backdrop saat sidebar terbuka) -->
      <div
        id="sidebar-overlay"
        class="fixed inset-0 bg-ink/40 z-30 hidden lg:hidden"
      ></div>

      <Topbar title={title} />

      <main class="flex-1 p-4 sm:p-6 lg:p-8 overflow-x-hidden">
        <slot />
      </main>

    </div>
  </div>

  <!-- Toast global -->
  <div id="toast" class="toast" role="alert" aria-live="polite">
    <span id="toast-msg"></span>
  </div>
</Base>

<script>
  import { getAdminAuth, adminApiFetch, clearAdminAuth, setAdminAuth, API_URL } from "../lib/auth";

  async function guardAuth(): Promise<void> {
    const { isAuthenticated } = getAdminAuth();
    if (!isAuthenticated) {
      window.location.replace("/login");
      return;
    }

    try {
      const res = await adminApiFetch(`${API_URL}/api/admin-auth/me`);
      if (!res.ok) {
        clearAdminAuth();
        window.location.replace("/login");
        return;
      }
     
      const json = await res.json().catch(() => null);
      const { token } = getAdminAuth();
      if (json?.data?.admin && token) {
        setAdminAuth(token, json.data.admin);
      }
    } catch {
      
    }

    document.getElementById("dashboard-root")?.classList.remove("hidden");
  }

  // Mobile sidebar toggle
  function initSidebarToggle(): void {
    const toggle = document.getElementById("sidebar-toggle");
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebar-overlay");

    function open(): void {
      sidebar?.classList.remove("-translate-x-full");
      overlay?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }
    function close(): void {
      sidebar?.classList.add("-translate-x-full");
      overlay?.classList.add("hidden");
      document.body.style.overflow = "";
    }

    toggle?.addEventListener("click", () => {
      const isOpen = !sidebar?.classList.contains("-translate-x-full");
      isOpen ? close() : open();
    });
    overlay?.addEventListener("click", close);
  }

  // Global toast helper
  function initToast(): void {
    window.showToast = (msg: string, type: "success" | "error" | "info" = "success") => {
      const toast = document.getElementById("toast");
      const toastMsg = document.getElementById("toast-msg");
      if (!toast || !toastMsg) return;

      toastMsg.textContent = msg;
      toast.classList.add("visible");

      if (type === "error") {
        toast.style.backgroundColor = "var(--color-signal)";
      } else {
        toast.style.backgroundColor = "var(--color-ink)";
      }

      clearTimeout((toast as HTMLElement & { _timer?: ReturnType<typeof setTimeout> })._timer);
      (toast as HTMLElement & { _timer?: ReturnType<typeof setTimeout> })._timer = setTimeout(() => {
        toast.classList.remove("visible");
      }, 3000);
    };
  }

  guardAuth();
  initSidebarToggle();
  initToast();
</script>