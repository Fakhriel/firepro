---
export interface Props {
  activeNav?: string;
}

const { activeNav = "" } = Astro.props;

const navItems = [
  { id: "dashboard",   href: "/owner",              label: "Dashboard",   icon: "grid",      group: "main" },
  { id: "users",       href: "/owner/users",         label: "Users",       icon: "users",     group: "main" },
  { id: "clients",     href: "/owner/clients",       label: "Clients",     icon: "user",      group: "main" },
  { id: "projects",    href: "/owner/projects",      label: "Projects",    icon: "briefcase", group: "ops" },
  { id: "quotations",  href: "/owner/quotations",    label: "Quotations",  icon: "file-text", group: "ops" },
  { id: "invoices",    href: "/owner/invoices",      label: "Invoices",    icon: "receipt",   group: "ops" },
  { id: "maintenance", href: "/owner/maintenance",   label: "Maintenance", icon: "tool",      group: "ops" },
  { id: "inventory",   href: "/owner/inventory",     label: "Inventory",   icon: "box",       group: "gudang" },
  { id: "reports",     href: "/owner/reports",       label: "Reports",     icon: "chart",     group: "gudang" },
  { id: "attendance",  href: "/owner/attendance",    label: "Attendance",  icon: "clock",     group: "gudang" },
  { id: "settings",    href: "/owner/settings",      label: "Settings",    icon: "cog",       group: "system" },
];

const groups: { key: string; label: string }[] = [
  { key: "main", label: "Utama" },
  { key: "ops", label: "Operasional" },
  { key: "gudang", label: "Gudang & Analitik" },
  { key: "system", label: "Sistem" },
];
---

<aside
  id="sidebar"
  class="fixed top-0 left-0 h-full w-60 bg-ink text-paper z-40 flex flex-col border-r-2 border-ink
         -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out"
>
  <!-- Brand -->
  <div class="flex items-center justify-between px-5 h-16 border-b border-paper/10 shrink-0">
    <a href="/owner" class="font-display text-2xl text-paper tracking-tight">FIREPRO</a>
    <span class="font-mono text-[9px] text-paper/40 uppercase tracking-widest border border-paper/20 px-1.5 py-0.5">
      owner
    </span>
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto py-4 px-3">
    {groups.map((group) => (
      <div class="mb-4">
        <p class="font-mono text-[9px] uppercase tracking-widest text-paper/35 px-2 mb-1.5">
          {group.label}
        </p>
        <ul class="space-y-0.5">
          {navItems.filter((item) => item.group === group.key).map((item) => {
            const isActive = activeNav === item.id;
            return (
              <li>
                <a
                  href={item.href}
                  class={`sidebar-link rounded-sm ${isActive ? "active" : ""}`}
                  style={isActive ? "background-color: rgba(240,239,233,0.1); color: #f0efe9; border-color: rgba(240,239,233,0.3);" : "color: rgba(240,239,233,0.55);"}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.icon === "grid" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                      <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                    </svg>
                  )}
                  {item.icon === "users" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                      <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                  )}
                  {item.icon === "user" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                    </svg>
                  )}
                  {item.icon === "briefcase" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <rect x="2" y="7" width="20" height="14" rx="2"/>
                      <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                    </svg>
                  )}
                  {item.icon === "file-text" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                      <polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
                    </svg>
                  )}
                  {item.icon === "receipt" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M4 2h16v20l-3-2-3 2-3-2-3 2-3-2-1 2z"/>
                      <line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="16" y2="11"/>
                    </svg>
                  )}
                  {item.icon === "tool" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                    </svg>
                  )}
                  {item.icon === "box" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                      <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                    </svg>
                  )}
                  {item.icon === "chart" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                  )}
                  {item.icon === "clock" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 16 14"/>
                    </svg>
                  )}
                  {item.icon === "cog" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <circle cx="12" cy="12" r="3"/>
                      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                  )}
                  <span>{item.label}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>

  <!-- User info + logout -->
  <div class="px-4 py-4 border-t border-paper/10 shrink-0">
    <div id="sidebar-user" class="flex items-center gap-3 mb-3">
      <div class="w-8 h-8 bg-signal flex items-center justify-center font-display text-paper text-sm shrink-0">
        <span id="sidebar-avatar">O</span>
      </div>
      <div class="min-w-0">
        <p id="sidebar-name" class="text-paper text-sm font-semibold truncate">Owner</p>
        <p id="sidebar-role" class="font-mono text-[9px] text-paper/40 uppercase tracking-widest">pemilik usaha</p>
      </div>
    </div>
    <button
      id="sidebar-logout"
      type="button"
      class="w-full flex items-center gap-2 px-3 py-2 font-body text-xs font-semibold text-signal hover:bg-signal/10 transition-colors duration-150 rounded-sm"
    >
      <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Keluar
    </button>
  </div>
</aside>

<script>
  // Prototype: belum terhubung ke auth backend owner — logout hanya redirect ke login.
  document.getElementById("sidebar-logout")?.addEventListener("click", () => {
    window.location.href = "/login";
  });
</script>
