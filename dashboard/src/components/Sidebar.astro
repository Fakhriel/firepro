---
export interface Props {
  activeNav?: string;
}

const { activeNav = "" } = Astro.props;

const navGroups = [
  {
    label: "Utama",
    items: [
      { id: "overview",  href: "/",          label: "Overview",   icon: "grid" },
      { id: "reports",   href: "/reports",   label: "Laporan",    icon: "chart" },
    ],
  },
  {
    label: "Gudang",
    items: [
      { id: "inventory",       href: "/inventory",       label: "Inventory",       icon: "box" },
      { id: "item-categories", href: "/item-categories", label: "Item Categories", icon: "tag" },
    ],
  },
  {
    label: "Operasional",
    items: [
      { id: "projects", href: "/projects", label: "Projects", icon: "bag" },
      { id: "invoices", href: "/invoices", label: "Invoices", icon: "credit" },
    ],
  },
  {
    label: "Pengguna",
    items: [
      { id: "clients", href: "/clients", label: "Clients", icon: "users" },
      { id: "admins",  href: "/admins",  label: "Admin",   icon: "shield" },
    ],
  },
  {
    label: "Lainnya",
    items: [
      { id: "settings", href: "/settings", label: "Pengaturan", icon: "settings" },
    ],
  },
];
---

<aside
  id="sidebar"
  class="fixed top-0 left-0 h-full w-60 bg-ink text-paper z-40 flex flex-col border-r-2 border-ink
         -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out"
>
  <!-- Brand -->
  <div class="flex items-center justify-between px-5 h-16 border-b border-paper/10 shrink-0">
    <a href="/" class="font-display text-2xl text-paper tracking-tight">FIREPRO</a>
    <span class="font-mono text-[9px] text-paper/40 uppercase tracking-widest border border-paper/20 px-1.5 py-0.5">
      admin
    </span>
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-5">
    {navGroups.map((group) => (
      <div>
        <p class="font-mono text-[9px] uppercase tracking-widest text-paper/35 px-2 mb-1.5">
          {group.label}
        </p>
        <ul class="space-y-0.5">
          {group.items.map((item) => {
            const isActive = activeNav === item.id;
            return (
              <li>
                <a
                  href={item.href}
                  class={`sidebar-link rounded-sm ${isActive ? "active" : ""}`}
                  style={isActive ? "background-color: rgba(240,239,233,0.1); color: #f0efe9; border-color: rgba(240,239,233,0.3);" : "color: rgba(240,239,233,0.55);"}
                  aria-current={isActive ? "page" : undefined}
                >
                  <!-- Icons inline SVG -->
                  {item.icon === "grid" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                      <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                    </svg>
                  )}
                  {item.icon === "chart" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                  )}
                  {item.icon === "box" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                      <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                    </svg>
                  )}
                  {item.icon === "tag" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                      <line x1="7" y1="7" x2="7.01" y2="7"/>
                    </svg>
                  )}
                  {item.icon === "bag" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M5.5 8H18.5L19.5 21H4.5L5.5 8Z"/><path d="M8.5 8V6C8.5 4.067 9.567 3 12 3C14.433 3 15.5 4.067 15.5 6V8"/>
                    </svg>
                  )}
                  {item.icon === "credit" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/>
                    </svg>
                  )}
                  {item.icon === "users" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                      <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                  )}
                  {item.icon === "shield" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                  )}
                  {item.icon === "settings" && (
                    <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                      <circle cx="12" cy="12" r="3"/>
                      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                  )}
                  <span>{item.label}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>

  <!-- User info + logout -->
  <div class="px-4 py-4 border-t border-paper/10 shrink-0">
    <div id="sidebar-user" class="flex items-center gap-3 mb-3">
      <div class="w-8 h-8 bg-signal flex items-center justify-center font-display text-paper text-sm shrink-0">
        <span id="sidebar-avatar">A</span>
      </div>
      <div class="min-w-0">
        <p id="sidebar-name" class="text-paper text-sm font-semibold truncate">Admin</p>
        <p id="sidebar-role" class="font-mono text-[9px] text-paper/40 uppercase tracking-widest">admin</p>
      </div>
    </div>
    <button
      id="sidebar-logout"
      type="button"
      class="w-full flex items-center gap-2 px-3 py-2 font-body text-xs font-semibold text-signal hover:bg-signal/10 transition-colors duration-150 rounded-sm"
    >
      <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Keluar
    </button>
  </div>
</aside>

<script>
  import { getAdminAuth, clearAdminAuth } from "../lib/auth";

  function initSidebar(): void {
    const { admin } = getAdminAuth();
    if (admin) {
      const name = document.getElementById("sidebar-name");
      const role = document.getElementById("sidebar-role");
      const avatar = document.getElementById("sidebar-avatar");
      if (name) name.textContent = admin.name;
      if (role) role.textContent = admin.username;
      if (avatar) avatar.textContent = admin.name.charAt(0).toUpperCase();
    }

    document.getElementById("sidebar-logout")?.addEventListener("click", () => {
      clearAdminAuth();
      window.location.replace("/login");
    });
  }

  initSidebar();
</script>