---
export interface Props {
  heading: string;
  sub?: string;
  crumbs?: { label: string; href?: string }[];
}

const { heading, sub, crumbs = [] } = Astro.props;
---

<div class="mb-6 sm:mb-8">
  {crumbs.length > 0 && (
    <nav class="flex items-center gap-1.5 font-mono text-[10px] text-smoke uppercase tracking-wide mb-2">
      {crumbs.map((crumb, i) => (
        <>
          {crumb.href ? (
            <a href={crumb.href} class="hover:text-ink transition-colors">{crumb.label}</a>
          ) : (
            <span class="text-ink">{crumb.label}</span>
          )}
          {i < crumbs.length - 1 && <span>/</span>}
        </>
      ))}
    </nav>
  )}
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
    <div>
      <h2 class="font-display text-3xl sm:text-4xl text-ink leading-none">{heading}</h2>
      {sub && <p class="font-mono text-xs text-smoke mt-2 uppercase tracking-wide">{sub}</p>}
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <slot />
    </div>
  </div>
</div>
<div class="border-b-2 border-ink mb-6 sm:mb-8"></div>