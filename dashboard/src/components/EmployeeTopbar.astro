---
export interface Props {
  title?: string;
}

const { title = "Dashboard" } = Astro.props;
---

<header class="sticky top-0 z-20 h-16 bg-paper border-b-2 border-ink flex items-center px-4 sm:px-6 gap-4 shrink-0">
  <!-- Mobile hamburger -->
  <button
    id="sidebar-toggle"
    type="button"
    aria-label="Buka navigasi"
    class="lg:hidden p-2 text-ink hover:text-signal transition-colors"
  >
    <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6" stroke="currentColor" stroke-width="1.75">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>

  <!-- Title -->
  <h1 class="font-display text-xl sm:text-2xl text-ink leading-none">{title}</h1>

  <div class="ml-auto flex items-center gap-3">
    <!-- Date badge -->
    <span id="topbar-date" class="hidden sm:inline font-mono text-xs text-smoke border border-hairline px-2.5 py-1.5">
      —
    </span>

    <!-- Attendance status pill -->
    <span id="topbar-attendance-pill" class="hidden sm:inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-widest text-smoke border border-hairline px-2.5 py-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-smoke"></span>
      Belum Check In
    </span>

    <!-- Notifications placeholder -->
    <button
      type="button"
      aria-label="Notifikasi"
      class="relative p-2 text-ink hover:text-signal transition-colors"
    >
      <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="1.75">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
      <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-signal rounded-full animate-alarm-pulse"></span>
    </button>
  </div>
</header>

<script>
  const dateEl = document.getElementById("topbar-date");
  if (dateEl) {
    dateEl.textContent = new Date().toLocaleDateString("id-ID", {
      weekday: "short",
      day: "numeric",
      month: "short",
      year: "numeric",
    });
  }
</script>
