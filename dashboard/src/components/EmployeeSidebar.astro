---
export interface Props {
  activeNav?: string;
}

const { activeNav = "" } = Astro.props;

const navItems = [
  { id: "dashboard", href: "/employee-technical", label: "Dashboard", icon: "grid" },
  { id: "tugas-saya", href: "/employee-technical/tugas-saya", label: "Tugas Saya", icon: "bag" },
  { id: "jadwal", href: "/employee-technical/jadwal", label: "Jadwal", icon: "calendar" },
  { id: "checklist", href: "/employee-technical/checklist", label: "Checklist", icon: "check" },
  { id: "upload-foto", href: "/employee-technical/upload-foto", label: "Upload Foto", icon: "camera" },
  { id: "riwayat-pekerjaan", href: "/employee-technical/riwayat-pekerjaan", label: "Riwayat Pekerjaan", icon: "history" },
  { id: "profil", href: "/employee-technical/profil", label: "Profil", icon: "user" },
];
---

<aside
  id="sidebar"
  class="fixed top-0 left-0 h-full w-60 bg-ink text-paper z-40 flex flex-col border-r-2 border-ink
         -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out"
>
  <!-- Brand -->
  <div class="flex items-center justify-between px-5 h-16 border-b border-paper/10 shrink-0">
    <a href="/employee-technical" class="font-display text-2xl text-paper tracking-tight">FIREPRO</a>
    <span class="font-mono text-[9px] text-paper/40 uppercase tracking-widest border border-paper/20 px-1.5 py-0.5">
      teknisi
    </span>
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto py-4 px-3">
    <p class="font-mono text-[9px] uppercase tracking-widest text-paper/35 px-2 mb-1.5">
      Lapangan
    </p>
    <ul class="space-y-0.5">
      {navItems.map((item) => {
        const isActive = activeNav === item.id;
        return (
          <li>
            <a
              href={item.href}
              class={`sidebar-link rounded-sm ${isActive ? "active" : ""}`}
              style={isActive ? "background-color: rgba(240,239,233,0.1); color: #f0efe9; border-color: rgba(240,239,233,0.3);" : "color: rgba(240,239,233,0.55);"}
              aria-current={isActive ? "page" : undefined}
            >
              {item.icon === "grid" && (
                <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                  <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                  <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                </svg>
              )}
              {item.icon === "bag" && (
                <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                  <path d="M5.5 8H18.5L19.5 21H4.5L5.5 8Z"/><path d="M8.5 8V6C8.5 4.067 9.567 3 12 3C14.433 3 15.5 4.067 15.5 6V8"/>
                </svg>
              )}
              {item.icon === "calendar" && (
                <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                  <rect x="3" y="4" width="18" height="18" rx="1"/><line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              )}
              {item.icon === "check" && (
                <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                  <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                </svg>
              )}
              {item.icon === "camera" && (
                <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                  <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                  <circle cx="12" cy="13" r="4"/>
                </svg>
              )}
              {item.icon === "history" && (
                <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                  <path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l4 2"/>
                </svg>
              )}
              {item.icon === "user" && (
                <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 shrink-0" stroke="currentColor" stroke-width="1.75">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
              )}
              <span>{item.label}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </nav>

  <!-- User info + logout -->
  <div class="px-4 py-4 border-t border-paper/10 shrink-0">
    <div id="sidebar-user" class="flex items-center gap-3 mb-3">
      <div class="w-8 h-8 bg-signal flex items-center justify-center font-display text-paper text-sm shrink-0">
        <span id="sidebar-avatar">T</span>
      </div>
      <div class="min-w-0">
        <p id="sidebar-name" class="text-paper text-sm font-semibold truncate">Teknisi Lapangan</p>
        <p id="sidebar-role" class="font-mono text-[9px] text-paper/40 uppercase tracking-widest">pekerja lapangan</p>
      </div>
    </div>
    <button
      id="sidebar-logout"
      type="button"
      class="w-full flex items-center gap-2 px-3 py-2 font-body text-xs font-semibold text-signal hover:bg-signal/10 transition-colors duration-150 rounded-sm"
    >
      <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="1.75">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Keluar
    </button>
  </div>
</aside>

<script>
  import { getAdminAuth, clearAdminAuth } from "../lib/auth";

  function initSidebar(): void {
    const { admin } = getAdminAuth();
    if (admin) {
      const nameEl = document.getElementById("sidebar-name");
      const avatarEl = document.getElementById("sidebar-avatar");
      if (nameEl) nameEl.textContent = admin.name || "Teknisi Lapangan";
      if (avatarEl) avatarEl.textContent = (admin.name || "T").charAt(0).toUpperCase();
    }

    document.getElementById("sidebar-logout")?.addEventListener("click", () => {
      clearAdminAuth();
      window.location.replace("/login");
    });
  }
  initSidebar();
</script>
