# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────
# Origin dashboard frontend (Astro dev server / production domain)
CORS_ORIGIN=http://localhost:4322

# ── Database (MySQL) ────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fireprodb
DB_USER=root
DB_PASSWORD=

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_with_secret_random_
JWT_EXPIRES_IN=8h

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change_password_default
SEED_ADMIN_NAME=Administrator

# ── DB schema sync (opsional, HATI-HATI) ────────────────
DB_SYNC_ALTER=false
